<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Categoria de Productos</title>
    <link rel="stylesheet" href="/public/css/styles.css">
    <link rel="shortcut icon" href="/public/img/logo_colon_sin_fondo.ico" type="image/x-icon">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        .main-container a {
            text-decoration: none;
            padding: 0.75rem 1.5rem;
            background-color: #4CAF50;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 1rem;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

        .container-contenido {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }

        .container-tablas {
            margin: 0;
        }

        .formCategoria,
        .formTalle,
        .formProductoEditar,
        .formEditarCategoria,
        .formEditarTalle {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            padding: 1rem;
        }

        .formCategoria label,
        .formTalle label,
        .formProductoEditar label,
        .formEditarCategoria label,
        .formEditarTalle label {
            font-weight: bold;
            font-size: 1rem;
            color: #333;
        }

        .formCategoria input,
        .formTalle input,
        .formProductoEditar input,
        .formEditarCategoria input,
        .formEditarTalle input,
        #tipoSocio,
        #deporte,
        #tipoSocioEditar,
        #deporteEditar {
            width: 100%;
            padding: 0.5rem;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 1rem;
            color: #333;
            background-color: #fff;
        }

        .formCategoria button,
        .formTalle button,
        .formProductoEditar button,
        .formEditarCategoria button,
        .formEditarTalle button {
            padding: 0.75rem 1.5rem;
            background-color: #4CAF50;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 1rem;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

        .formCategoria button:hover,
        .formTalle button:hover,
        .formProductoEditar button:hover,
        .formEditarCategoria button:hover,
        .formEditarTalle button:hover {
            background-color: #45a049;
        }

        .formCategoria button:active,
        .formTalle button:active,
        .formProductoEditar button:active,
        .formEditarCategoria button:active,
        .formEditarTalle button:active {
            background-color: #3e8e41;
        }

        .preview-wrap{
        display:flex; justify-content:center; align-items:center; margin-top:12px;
        }

        .preview-box{
          width: 280px; height: 200px;
          border: 2px dashed #ccc; border-radius: 12px;
          display:flex; justify-content:center; align-items:center;
          overflow:hidden; background:#fafafa;
        }

        .preview-box img { 
          max-width:100%; max-height:100%; object-fit:contain; 
        }

        .file-help{ 
          font-size:12px; color:#666; text-align:center; margin-top:6px; 
        }

        .formCategoria label, .formEditarCategoria label, .formEditarTalle label{ 
          display:block; margin-top:8px; font-weight:600; 
        }

        .formCategoria input, .formCategoria textarea, .formCategoria select, .formTalle textarea, 
        .formEditarCategoria textarea, .formEditarTalle textarea{
          width:100%; padding:8px; border:1px solid #ddd; border-radius:8px; margin-top:4px;
        }

        .formCategoria button, .formEditarCategoria button, .formEditarTalle button{ 
          margin-top:12px; width:100%; padding:10px; border-radius:10px; 
        }

        /* Small <= 768px */
        @media screen and (max-width: 768px) {
            .container-contenido {
                grid-template-columns: 1fr;
            }
        }
        
    </style>
  </head>
  <body>
    <div class="grid-container">
      <%- include('header') %> <%- include('sidebar',{ rolId: rolId,
      rolNombre:rolNombre, disciplinas:disciplinas }) %>

      <!-- Main -->
      <main class="main-container">
        <h1>CATEGORIAS Y TALLES</h1>
        
        <!-- Botón para agregar categorias -->
        

        <div class="container-contenido">
            <div class="container-tablas">
                <h2 style="margin-top: 0;">Categorias</h2>
            <div class="tabla-header">
                <div>
                </div>
                <button style="padding: 10px;" onclick="añadirCategoria()" class="btn btn-primary">Agregar Categoria</button>
            </div>
            <table>
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (categorias.length> 0) { %>
                        <% categorias.forEach(function(categoria) { %>
                            <tr>
                                <td><%= categoria.nombre %></td>
                                <td><%= categoria.descripcion %></td>
                                <td>
                                    <button onclick="editarCategoria(<%= JSON.stringify(categoria) %>)">Editar</button>
                                    <button onclick="borrarCategoria(<%= categoria.id_categoria %>)">Eliminar</button>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                            <tr>
                                <td colspan="8" style="text-align: center;">No hay categorias registrados</td>
                            </tr>
                    <% } %>
                </tbody>
            </table>
            </div>
            <div class="container-tablas">
                <h2 style="margin-top: 0;">Talles</h2>
                <div class="tabla-header">
                    <div>
                    </div>
                    <button style="padding: 10px;" onclick="añadirTalle()" class="btn btn-primary">Agregar Talle</button>
                </div>
                <table>
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Descripción</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (talles.length> 0) { %>
                            <% talles.forEach(function(talle) { %>
                                <tr>
                                    <td><%= talle.nombre %></td>
                                    <td><%= talle.descripcion %></td>
                                    <td>
                                        <button onclick="editarTalle(<%= JSON.stringify(talle) %>)">Editar</button>
                                        <button onclick="borrarTalle(<%= talle.id_talle %>)">Eliminar</button>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                                <tr>
                                    <td colspan="8" style="text-align: center;">No hay categorias registrados</td>
                                </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
        
      </main>

      <!-- End Main -->
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/public/js/interacciones.js"></script>
    
    <script>

        function añadirCategoria() {
            Swal.fire({
                title: 'Agregar nueva categoria',
                html: `
                    <form class="formCategoria">
                        <label for="nombre">Nombre:</label>
                        <input type="text" id="nombre" required>
                        <label for="descripcion">Descripción:</label>
                        <textarea id="descripcion"></textarea>
                        
                        <button type="submit">Guardar Categoria</button>
                    </form>
                    <div class="error-message"></div>
                `,
                showConfirmButton: false,
                showCloseButton: true,
                showCancelButton: false,
                allowOutsideClick: false,
            })

            document.querySelector(".formCategoria").addEventListener("submit", (e) => {
                e.preventDefault()

                const nombre = document.getElementById('nombre').value;
                const descripcion = document.getElementById('descripcion').value;

                
                fetch('/crearCategoria', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        nombre: nombre,
                        descripcion: descripcion,
                    }),
                })
                    .then((response) => response.json())
                    .then((data) => {
                        if (data.ok) {
                            Swal.fire({
                                title: "Categoria creada!",
                                text: data.message,
                                icon: "success",
                                showConfirmButton: false,
                                timer: 2000,
                                timerProgressBar: true,
                                didClose: () => {
                                    window.location.reload()
                                } 
                            })
                        } else {
                            errorMessage.textContent = data.message
                        }
                    })
                    .catch((error) => console.error(error));
                    
            })
        }

        function añadirTalle() {
            Swal.fire({
                title: 'Agregar nuevo talle',
                html: `
                    <form class="formTalle">
                        <label for="nombre">Nombre:</label>
                        <input type="text" id="nombre" required>
                        <label for="descripcion">Descripción:</label>
                        <textarea id="descripcion"></textarea>
                        
                        <button type="submit">Guardar Talle</button>
                    </form>
                    <div class="error-message"></div>
                `,
                showConfirmButton: false,
                showCloseButton: true,
                showCancelButton: false,
                allowOutsideClick: false,
            })

            document.querySelector(".formTalle").addEventListener("submit", (e) => {
                e.preventDefault()

                const nombre = document.getElementById('nombre').value;
                const descripcion = document.getElementById('descripcion').value;

                
                fetch('/crearTalle', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        nombre: nombre,
                        descripcion: descripcion
                    }),
                })
                    .then((response) => response.json())
                    .then((data) => {
                        if (data.ok) {
                            Swal.fire({
                                title: "Talle creado!",
                                text: data.message,
                                icon: "success",
                                showConfirmButton: false,
                                timer: 2000,
                                timerProgressBar: true,
                                didClose: () => {
                                    window.location.reload()
                                } 
                            })
                        } else {
                            errorMessage.textContent = data.message
                        }
                    })
                    .catch((error) => console.error(error));
                    
            })
        }

        function editarCategoria(categoria) {
            Swal.fire({
                title: 'Editar categoria',
                html: `
                    <form class="formEditarCategoria">
                        <label for="nombre">Nombre:</label>
                        <input value="${categoria.nombre}" type="text" id="nombre" required>
                        <label for="descripcion">Descripción:</label>
                        <textarea id="descripcion">${categoria.descripcion}</textarea>
                        
                        <button type="submit">Guardar Categoria</button>
                    </form>
                    <div class="error-message"></div>
                `,
                showConfirmButton: false,
                showCloseButton: true,
                showCancelButton: false,
                allowOutsideClick: false,
            })

            document.querySelector(".formEditarCategoria").addEventListener("submit", (e) => {
                e.preventDefault()

                const nombre = document.getElementById('nombre').value;
                const descripcion = document.getElementById('descripcion').value;

                
                fetch(`/editarCategoria/${categoria.id_categoria}`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        nombre: nombre,
                        descripcion: descripcion
                    }),
                })
                    .then((response) => response.json())
                    .then((data) => {
                        if (data.ok) {
                            Swal.fire({
                                title: "Categoria actualizada!",
                                text: data.message,
                                icon: "success",
                                showConfirmButton: false,
                                timer: 2000,
                                timerProgressBar: true,
                                didClose: () => {
                                    window.location.reload()
                                } 
                            })
                        } else {
                            errorMessage.textContent = data.message
                        }
                    })
                    .catch((error) => console.error(error));
                    
            })    
        }

        function editarTalle(talle) {
            Swal.fire({
                title: 'Editar talle',
                html: `
                    <form class="formEditarTalle">
                        <label for="nombre">Nombre:</label>
                        <input value="${talle.nombre}" type="text" id="nombre" required>
                        <label for="descripcion">Descripción:</label>
                        <textarea id="descripcion">${talle.descripcion}</textarea>
                        
                        <button type="submit">Guardar Talle</button>
                    </form>
                    <div class="error-message"></div>
                `,
                showConfirmButton: false,
                showCloseButton: true,
                showCancelButton: false,
                allowOutsideClick: false,
            })

            document.querySelector(".formEditarTalle").addEventListener("submit", (e) => {
                e.preventDefault()

                const nombre = document.getElementById('nombre').value;
                const descripcion = document.getElementById('descripcion').value;

                
                fetch(`/editarTalle/${talle.id_talle}`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        nombre: nombre,
                        descripcion: descripcion
                    }),
                })
                    .then((response) => response.json())
                    .then((data) => {
                        if (data.ok) {
                            Swal.fire({
                                title: "Talle actualizado!",
                                text: data.message,
                                icon: "success",
                                showConfirmButton: false,
                                timer: 2000,
                                timerProgressBar: true,
                                didClose: () => {
                                    window.location.reload()
                                } 
                            })
                        } else {
                            errorMessage.textContent = data.message
                        }
                    })
                    .catch((error) => console.error(error));
                    
            })
        }

        function borrarCategoria(id) {
            Swal.fire({
                title: "Estas seguro?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                cancelButtonText: "Cancelar",
                confirmButtonText: "Borrar"
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch(`/eliminarCategoria/${id}`, {
                        method: 'DELETE',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    }).then((response) => response.json())
                        .then((data) => {
                            if (data.ok) {
                                Swal.fire({
                                    title: "Borrado!",
                                    text: `${data.message}`,
                                    icon: "success",
                                    showConfirmButton: false,
                                    timer: 2000,
                                    timerProgressBar: true,
                                    didClose: () => {
                                        window.location.reload()
                                    } 
                                })
                            } else {
                                console.error('Response error:', data.message);
                            }
                        })
                        .catch(error => console.error('Error:', error));
                }
            });
        }

        function borrarTalle(id) {
            Swal.fire({
                title: "Estas seguro?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                cancelButtonText: "Cancelar",
                confirmButtonText: "Borrar"
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch(`/eliminarTalle/${id}`, {
                        method: 'DELETE',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    }).then((response) => response.json())
                        .then((data) => {
                            if (data.ok) {
                                Swal.fire({
                                    title: "Borrado!",
                                    text: `${data.message}`,
                                    icon: "success",
                                    showConfirmButton: false,
                                    timer: 2000,
                                    timerProgressBar: true,
                                    didClose: () => {
                                        window.location.reload()
                                    } 
                                })
                            } else {
                                console.error('Response error:', data.message);
                            }
                        })
                        .catch(error => console.error('Error:', error));
                }
            });
        }

      </script>
  </body>
</html>