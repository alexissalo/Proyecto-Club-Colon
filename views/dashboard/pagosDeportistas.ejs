<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="shortcut icon" href="/public/img/logo_colon_sin_fondo.ico" type="image/x-icon">
    <link rel="stylesheet" href="/public/css/styles.css">
    <style>
        .resumen-saldo {
            margin: 20px auto;
            background-color: #fff;
            padding: 20px;
            border-radius: 5px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            overflow-x: hidden;
        }

        .estado-pendiente {
            color: red;
        }

        .estado-pagado {
            color: green;
        }
    </style>
    <title>Pagos del Deportista</title>
</head>

<body>
    <div class="grid-container">
        <%- include('header') %>
            <%- include('sidebar', { rolId: rolId, rolNombre: rolNombre, disciplinas: disciplinas }) %>

                <!-- Main -->
                <main class="main-container">
                    <div class="main-title">
                        <h2>Pagos del Deportista: <%= deportista.nombre %> (DNI: <%= deportista.dni %>)</h2>
                    </div>

                    <div class="container-tablas-pagos">
                        <!-- Resumen del saldo pendiente -->
                        <div class="resumen-saldo">
                            <h3>Deuda Pendiente</h3>
                            <p>Total a pagar: <strong>$<%= totalPendiente %></strong></p>
                        </div>

                        <!-- Tabla de facturas pendientes -->
                        <div>
                            <div class="container-tablas">
                                <h3>Facturas Pendientes</h3>
                                <table>
                                    <thead>
                                        <tr>
                                            <th>ID</th>
                                            <th>Fecha de Emisión</th>
                                            <th>Monto</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (facturasPendientes.length> 0) { %>
                                            <% facturasPendientes.forEach(factura=> { %>
                                                <tr>
                                                    <td>
                                                        <%= factura.id %>
                                                    </td>
                                                    <td>
                                                        <%= factura.fecha_emision %>
                                                    </td>
                                                    <td>$<%= factura.monto %>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="3">No hay facturas pendientes.</td>
                                                        </tr>
                                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>


                        <div>
                            <!-- Tabla de facturas pagadas -->
                            <div class="container-tablas">
                                <h3>Facturas Pagadas</h3>
                                <table>
                                    <thead>
                                        <tr>
                                            <th>ID</th>
                                            <th>Fecha de Emisión</th>
                                            <th>Monto</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (facturasPagadas.length> 0) { %>
                                            <% facturasPagadas.forEach(factura=> { %>
                                                <tr>
                                                    <td>
                                                        <%= factura.id %>
                                                    </td>
                                                    <td>
                                                        <%= factura.fecha_emision %>
                                                    </td>
                                                    <td>$<%= factura.monto %>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="3">No hay facturas pagadas.</td>
                                                        </tr>
                                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </main>
                <!-- End Main -->
    </div>

    <script src="/public/js/interacciones.js"></script>
</body>

</html>