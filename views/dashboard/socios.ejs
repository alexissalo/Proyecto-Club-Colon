<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="shortcut icon" href="/public/img/logo_colon_sin_fondo.ico" type="image/x-icon">
    <link rel="stylesheet" href="/public/css/styles.css">
    <title>Socios</title>
    <style>
        td i {
            cursor: pointer;
            margin: 5px;
            padding: 5px;
            border-radius: 10px;
        }

        td i:hover {
            background-color: #ccc;
        }

        .formSocio,
        .formSocioEditar,
        .formSocioPago {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            padding: 1rem;
        }

        .formSocio label,
        .formSocioEditar label,
        .formSocioPago label {
            font-weight: bold;
            font-size: 1rem;
            color: #333;
        }

        .formSocio input,
        .formSocioEditar input,
        .formSocioPago input,
        .formSocioPago select,
        #tipoSocio,
        #deporte,
        #tipoSocioEditar,
        #deporteEditar {
            width: 100%;
            padding: 0.5rem;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 1rem;
            color: #333;
            background-color: #fff;
        }

        .formSocio button,
        .formSocioEditar button,
        .formSocioPago button {
            padding: 0.75rem 1.5rem;
            background-color: #4CAF50;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 1rem;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

        .formSocio button:hover,
        .formSocioEditar button:hover,
        .formSocioPago button:hover {
            background-color: #45a049;
        }

        .formSocio button:active,
        .formSocioEditar button:active,
        .formSocioPago button:active {
            background-color: #3e8e41;
        }

        .botonlistadodeudores {
            background-color: #2889dd;
            color: white;
            font-weight: 500;
            border: none;
            margin: 10px 10px 10px 0px;
            padding: 10px;
            border-radius: 5px;
            cursor: pointer;
        }

        .botonlistadodeudores:hover {
            background-color: #2772b3;
        }
    </style>
</head>

<body>
    <div class="grid-container">
        <%- include('header') %>
            <%- include('sidebar',{ rolId: rolId,rolNombre:rolNombre, disciplinas:disciplinas }) %>

                <!-- Main -->
                <main class="main-container">
                    <div class="main-title">
                        <h2>SOCIOS</h2>
                    </div>
                    <div class="container-tablas">
                        <div class="tabla-header">
                            <div>
                                <form action="" method="GET" class="search-bar">
                                    <input type="text" name="buscar" class="search-input"
                                        placeholder="Buscar por nombre o DNI..."
                                        value="<%= typeof buscar !== 'undefined' ? buscar : '' %>">
                                    <button type="submit" class="search-button">Buscar</button>
                                </form>
                            </div>
                            <button onclick="añadirSocio()">Nuevo socio</button>
                        </div>
                        <table>
                            <thead>
                                <tr>
                                    <th>Nombre</th>
                                    <th>Dni</th>
                                    <th>Fec.Nac</th>
                                    <th>Telefono</th>
                                    <th>Domicilio</th>
                                    <th>Fec.Inscripcion</th>
                                    <th>Email</th>
                                    <th>Tipo de socio</th>
                                    <th>Deporte</th>
                                    <th>Estado</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (socios.length> 0) { %>
                                    <% socios.forEach(function(socio) { %>
                                        <tr>
                                            <td>
                                                <%= socio.nombre %>
                                            </td>
                                            <td>
                                                <%= socio.dni %>
                                            </td>
                                            <td>
                                                <%= socio.fechaNacimiento %>
                                            </td>
                                            <td>
                                                <%= socio.telefono %>
                                            </td>
                                            <td>
                                                <%= socio.domicilio %>
                                            </td>
                                            <td>
                                                <%= socio.fechaInscripcion %>
                                            </td>
                                            <td>
                                                <%= socio.email %>
                                            </td>
                                            <td style="text-transform: capitalize;">
                                                <%= socio.tipodesocio %>
                                            </td>
                                            <td style="text-transform: capitalize;">
                                                <% if (socio.deporte) { %>
                                                    <%= socio.deporte %>

                                                        <% }else{ %>
                                                            No realiza deporte
                                                            <% } %>
                                            </td>
                                            <td style="text-transform: capitalize;">
                                                <%= socio.estado %>
                                            </td>
                                            <td>
                                                <% if (socio.estado=="activo") { %>
                                                    <i class="bi bi-person-down" title="Dar de Baja" onclick="darDeBajaSocio(<%= socio.id%>)"></i>
                                                <% }else{ %>
                                                    <i class="bi bi-person-up" title="Dar de Alta" onclick="darDeAltaSocio(<%= socio.id%>)"></i>
                                                <% } %>
                                                <i class="bi bi-clipboard" title="Ver Pagos"
                                                    onclick="window.location.href=`/dashboard/socios/pagos/<%= socio.id%>`"></i>
                                                <i class="bi bi-cash" title="Pagos"
                                                    onclick="crearPago(<%= JSON.stringify(socio) %>)"></i>
                                                <i class="bi bi-pencil-fill" title="Editar"
                                                    onclick="editarSocio(<%= JSON.stringify(socio) %>)"></i>
                                                <i class="bi bi-trash-fill" title="Eliminar"
                                                    onclick="borrarSocio(<%= socio.id%>)"></i>
                                            </td>
                                        </tr>
                                        <% }); %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="8" style="text-align: center;">No hay socios
                                                        registrados</td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                        <div class="pagination">
                            <div class="pagination-select">
                                Filas por pagina:
                                <select
                                    onchange="window.location.href = '?pagina=1&filasPorPagina=' + this.value + '&buscar=<%= typeof buscar !== 'undefined' ? buscar : '' %>'">
                                    <option value="5" <%=filasPorPagina==5 ? 'selected' : '' %>>5</option>
                                    <option value="10" <%=filasPorPagina==10 ? 'selected' : '' %>>10</option>
                                    <option value="20" <%=filasPorPagina==20 ? 'selected' : '' %>>20</option>
                                </select>
                            </div>
                            <div class="pagination-buttons">
                                <button class="pagination-button" onclick="navigatePage('prev')" <%=pagina===1
                                    ? 'disabled' : '' %>>
                                    <i class="bi bi-chevron-left"></i>
                                </button>
                                <span>
                                    <%= (pagina - 1) * filasPorPagina + 1 %> - <%= Math.min(pagina * filasPorPagina,
                                            totalSocios) %> de <%= totalSocios %>
                                </span>
                                <button class="pagination-button" onclick="navigatePage('next')" <%=pagina>=
                                    Math.ceil(totalSocios / filasPorPagina) ? 'disabled' : '' %>>
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </div>
                        </div>
                        <div class="dropdown">
                            <button class="botonlistadodeudores" type="button" data-bs-toggle="dropdown"
                                aria-expanded="false">
                                Acciones
                            </button>
                            <ul class="dropdown-menu">
                                <li onclick="modalListaDeudores()">Listado de deudores</li>
                                <li id="downloadExcel"><i class="bi bi-file-earmark-spreadsheet"></i> Exportar a Excel
                                </li>
                                <li id="downloadPdf"><i class="bi bi-filetype-pdf"></i> Exportar a PDF</li>
                            </ul>
                        </div>
                    </div>
                </main>
                <!-- End Main -->
    </div>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous"></script>
    <script src="/public/js/interacciones.js"></script>
    <script>

        const tiposDeSociosData = <%- JSON.stringify(tiposdesocios) %>;
        const disciplinaData = <%- JSON.stringify(disciplinas) %>;

        function navigatePage(direction) {
            const paginaActual = <%= pagina %>;
            const filasPorPaginas = <%= filasPorPagina %>;
            const buscar = '<%= typeof buscar !== "undefined" ? buscar : "" %>';
            let nuevaPagina;

            if (direction === 'prev') {
                nuevaPagina = paginaActual - 1;
            } else if (direction === 'next') {
                nuevaPagina = paginaActual + 1;
            }

            window.location.href = `?pagina=${nuevaPagina}&filasPorPagina=${filasPorPaginas}&buscar=${buscar}`;
        }

        function verDetalle(socio) {
            const contenido = `
                    <h2 style="text-align:center; margin-bottom: 20px;">Pagos de la cuota</h2>
                    <div style="max-height: 300px; overflow-y: auto;"> <!-- Limitar la altura con scrollbar -->
                        <table style="width:100%; border-collapse: collapse;">
                            <thead>
                                <tr>
                                    <th style="padding: 10px; border-bottom: 2px solid #ccc; text-align:left; background-color: #f4f4f4;">N° de Referencia</th>
                                    <th style="padding: 10px; border-bottom: 2px solid #ccc; text-align:left; background-color: #f4f4f4;">Fecha de pago</th>
                                    <th style="padding: 10px; border-bottom: 2px solid #ccc; text-align:left; background-color: #f4f4f4;">Monto</th>
                                </tr>
                            </thead>
                            <tbody>
                                ${socio.pagos && socio.pagos.length > 0 ? socio.pagos.map((pago) => `
                                <tr>
                                    <td style="padding: 10px; border-bottom: 1px solid #ddd; text-align: left;">${pago.idPago}</td>
                                    <td style="padding: 10px; border-bottom: 1px solid #ddd; text-align: left;">${pago.fecha}</td>
                                    <td style="padding: 10px; border-bottom: 1px solid #ddd; text-align: left;">$${pago.valor}</td>
                                </tr>
                                `).join('')
                    : `
                                <tr>
                                    <td colspan="2" style="padding: 10px; text-align: center; color: #999;">Sin pagos registrados</td>
                                </tr>`}
                            </tbody>
                        </table>
                    </div>
                `;

            // Muestra el modal con SweetAlert
            Swal.fire({
                html: contenido,
                showConfirmButton: false,
                showCloseButton: true,
                showCancelButton: false,
            });
        }



        function añadirSocio() {
            const tiposDeSociosHtml = tiposDeSociosData.map((tipoSocio) => {
                return `<option value="${tipoSocio.id}">${tipoSocio.nombre}</option>`;
            }).join('');
            const disciplinasHtml = disciplinaData.map((disciplina) => {
                return `<option value="${disciplina.id}">${disciplina.nombre}</option>`;
            }).join('');
            Swal.fire({
                title: 'Agregar nuevo socio',
                html: `
                    <form class="formSocio">
                        <label for="nombre">Nombre:</label>
                        <input type="text" id="nombre" required>
                        <label for="telefono">Teléfono:</label>
                        <input type="tel" id="telefono" required>
                        <label for="domicilio">Domicilio:</label>
                        <input type="text" id="domicilio" required>
                        <label for="dni">DNI:</label>
                        <input type="number" id="dni" required>
                        <label for="fechaInscripcion">Fecha de inscripcion:</label>
                        <input type="date" id="fechaInscripcion" required>
                        <label for="fechaNacimiento">Fecha de nacimiento:</label>
                        <input type="date" id="fechaNacimiento" required>
                        <label for="email">Email:</label>
                        <input type="email" id="email" required>
                        <label for="tipoSocio">Tipo de socio:</label>
                        <select id="tipoSocio" required>
                            ${tiposDeSociosHtml}
                        </select>
                        <label for="deporte">Deporte:</label>
                        <select id="deporte" required>
                            <option value=0>No realiza deporte</option>
                            ${disciplinasHtml}
                        </select>
                        <button type="submit">Guardar Socio</button>
                    </form>
                    <div class="error-message"></div>
                `,
                showConfirmButton: false,
                showCloseButton: true,
                showCancelButton: false,
                allowOutsideClick: false,
            });

            document.querySelector(".formSocio").addEventListener("submit", (e) => {
                e.preventDefault()

                const nombre = document.getElementById('nombre').value;
                const telefono = document.getElementById('telefono').value;
                const domicilio = document.getElementById('domicilio').value;
                const dni = document.getElementById('dni').value;
                const fechaNacimiento = document.getElementById('fechaNacimiento').value;
                const fechaInscripcion = document.getElementById('fechaInscripcion').value;
                const email = document.getElementById("email").value
                const tipoSocio = document.getElementById('tipoSocio').value;
                const deporte = document.getElementById('deporte').value;
                const errorMessage = document.querySelector(".error-message");

                fetch('/crearSocio', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        nombre: nombre,
                        telefono: telefono,
                        domicilio: domicilio,
                        dni: dni,
                        fechaNacimiento: fechaNacimiento,
                        fechaInscripcion: fechaInscripcion,
                        email: email,
                        tipodesocio: tipoSocio,
                        deporte: deporte
                    }),
                })
                    .then((response) => response.json())
                    .then((data) => {
                        if (data.ok) {
                            Swal.fire({
                                title: "Socio creado!",
                                text: data.message,
                                icon: "success",
                                showConfirmButton: false,
                                timer: 2000,
                                timerProgressBar: true,
                                didClose: () => {
                                    window.location.reload()
                                } 
                            })
                        } else {
                            errorMessage.textContent = data.message
                        }
                    })
                    .catch((error) => console.error(error));
            })
        }

        function borrarSocio(id) {
            Swal.fire({
                title: "Estas seguro?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                cancelButtonText: "Cancelar",
                confirmButtonText: "Borrar"
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch(`/borrarSocio/${id}`, {
                        method: 'DELETE',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    }).then((response) => response.json())
                        .then((data) => {
                            if (data.ok) {
                                Swal.fire({
                                    title: "Borrado!",
                                    text: `${data.message}`,
                                    icon: "success",
                                    showConfirmButton: false,
                                    timer: 2000,
                                    timerProgressBar: true,
                                    didClose: () => {
                                        window.location.reload()
                                    } 
                                })
                            } else {
                                console.error('Response error:', data.message);
                            }
                        })
                        .catch(error => console.error('Error:', error));
                }
            });
        }

        function editarSocio(socio) {
            const tiposDeSociosHtml = tiposDeSociosData.map((tipoSocio) => {
                const selected = socio.tipodesocio === tipoSocio.nombre ? 'selected' : '';
                return `<option value="${tipoSocio.id}" ${selected}>${tipoSocio.nombre}</option>`;
            }).join('');

            const disciplinasHtml = disciplinaData.map((disciplina) => {
                const selected = socio.deporte === disciplina.nombre ? 'selected' : '';
                return `<option value="${disciplina.id}" ${selected}>${disciplina.nombre}</option>`;
            }).join('');

            Swal.fire({
                title: 'Editar socio',
                html: `
            <form class="formSocioEditar">
                <label for="nombre">Nombre:</label>
                <input type="text" id="nombreEditar" value="${socio.nombre}" required>
                <label for="telefono">Teléfono:</label>
                <input type="tel" id="telefonoEditar" value="${socio.telefono}" required>
                <label for="domicilio">Domicilio:</label>
                <input type="text" id="domicilioEditar" value="${socio.domicilio}" required>
                <label for="emailEditar">Email:</label>
                <input type="email" id="emailEditar" value="${socio.email || ""}" required>
                <label for="tipoSocio">Tipo de socio:</label>
                <select id="tipoSocioEditar" required>
                    ${tiposDeSociosHtml}
                </select>
                <label for="deporte">Deporte:</label>
                <select id="deporteEditar" required>
                    <option value="0" ${socio.deporte === 0 ? 'selected' : ''}>No realiza deporte</option>
                    ${disciplinasHtml}
                </select>
                <button type="submit">Guardar Cambios</button>
            </form>
            <div class="error-message" style="color: red; margin-top: 10px;"></div>
        `,
                showConfirmButton: false,
                showCloseButton: true,
                showCancelButton: false,
                allowOutsideClick: false,
            });

            document.querySelector(".formSocioEditar").addEventListener("submit", (e) => {
                e.preventDefault();

                const nombre = document.getElementById('nombreEditar').value;
                const telefono = document.getElementById('telefonoEditar').value;
                const domicilio = document.getElementById('domicilioEditar').value;
                const email = document.getElementById("emailEditar").value
                const tipoSocio = document.getElementById('tipoSocioEditar').value;
                const deporte = document.getElementById('deporteEditar').value;
                const errorMessage = document.querySelector(".error-message");

                fetch(`/actualizarSocio/${socio.id}`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        nombre: nombre,
                        telefono: telefono,
                        domicilio: domicilio,
                        tipodesocio: tipoSocio,
                        deporte: deporte,
                        email: email
                    }),
                })
                    .then((response) => response.json())
                    .then((data) => {
                        if (data.ok) {
                            Swal.fire({
                                title: "Socio actualizado!",
                                text: data.message,
                                icon: "success",
                                showConfirmButton: false,
                                timer: 2000,
                                timerProgressBar: true,
                                didClose: () => {
                                    window.location.reload()
                                } 
                            })
                        } else {
                            // Mostrar el mensaje de error en el modal
                            errorMessage.textContent = data.message;
                        }
                    })
                    .catch((error) => {
                        // En caso de error en la petición, mostrar mensaje en el modal
                        errorMessage.textContent = "Error en la actualización. Inténtalo nuevamente.";
                    });
            });
        }

        function crearPago(socio) {
    // Solicitar las facturas impagas del socio
    fetch(`/listarFacturasImpagas/${socio.id}`)
        .then(response => response.json())
        .then(res => {
            if (!res.ok) {
                console.error('Error al obtener facturas:', res.message);
                return;
            }

            const facturas = res.data; // Array de facturas impagas
            const facturasHtml = `
            <div class="container-tablas">
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Monto</th>
                            <th>Fecha de Emision</th>
                            <th>Seleccionar</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${facturas && facturas.length > 0 ? facturas.map(factura => `
                        <tr>
                            <td>${factura.id}</td>
                            <td class="monto">$${factura.monto}</td>
                            <td>${factura.fecha_emision}</td>
                            <td>
                                <input type="checkbox" class="factura-checkbox" data-monto="${factura.monto}" value="${factura.id}">
                            </td>
                        </tr>`).join('') :
                        `
                        <tr>
                            <td colspan="4" style="padding: 10px; text-align: center;">No se encuentran facturas</td>
                        </tr>
                        `}
                    </tbody>
                </table>
            </div>
            `;

            // Mostrar el modal con las facturas
            Swal.fire({
                title: 'Crear pago',
                html: `
                <form class="formSocioPago">
                    <div>
                        <h4>Selecciona las facturas a pagar:</h4>
                        ${facturasHtml}
                    </div>
                    <div id="monto-total" style="margin-top: 10px; font-weight: bold;">Monto total: $0</div>
                    <label>Método de pago:</label>
                    <select required>
                        <option value="Efectivo">Efectivo</option>
                        <option value="Transferencia">Transferencia</option>
                    </select>
                    <button type="submit">Guardar Pago</button>
                </form>
                <div class="error-message" style="color: red; margin-top: 10px;"></div>
                `,
                showConfirmButton: false,
                showCloseButton: true,
                allowOutsideClick: false,
            });

            // Actualizar el monto total cuando cambian las selecciones
            const checkboxes = document.querySelectorAll(".factura-checkbox");
            const totalDisplay = document.querySelector("#monto-total");

            checkboxes.forEach(checkbox => {
                checkbox.addEventListener("change", () => {
                    const total = Array.from(checkboxes)
                        .filter(cb => cb.checked)
                        .reduce((sum, cb) => sum + parseFloat(cb.dataset.monto), 0);

                    totalDisplay.textContent = `Monto total: $${total.toFixed(2)}`;
                });
            });

            // Manejar el envío del formulario
            document.querySelector(".formSocioPago").addEventListener("submit", (e) => {
                e.preventDefault();

                // Recoger las facturas seleccionadas
                const facturasSeleccionadas = Array.from(document.querySelectorAll(".factura-checkbox:checked"))
                    .map(checkbox => checkbox.value);

                if (facturasSeleccionadas.length === 0) {
                    const errorMessage = document.querySelector(".error-message");
                    errorMessage.textContent = "Debes seleccionar al menos una factura.";
                    return;
                }

                const metodoDePago = document.querySelector(".formSocioPago select").value;

                const infoPago = {
                    id_socio: socio.id,
                    facturas: facturasSeleccionadas,
                    metodoPago: metodoDePago,
                    monto: parseFloat(totalDisplay.textContent.replace("Monto total: $", "")),
                };

                // Enviar los datos al servidor
                fetch(`/crearPago`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(infoPago),
                })
                    .then((response) => response.json())
                    .then((data) => {
                        if (data.ok) {
                            Swal.fire({
                                title: "Pago registrado",
                                text: "El pago fue registrado exitosamente.",
                                icon: "success",
                                showConfirmButton: false,
                                timer: 2000,
                                timerProgressBar: true,
                                didClose: () => {
                                    window.location.reload()
                                } 
                            })
                        } else {
                            const errorMessage = document.querySelector(".error-message");
                            errorMessage.textContent = data.message || "Error al registrar el pago.";
                        }
                    })
                    .catch((error) => {
                        console.error('Error:', error);
                        const errorMessage = document.querySelector(".error-message");
                        errorMessage.textContent = "Error en el servidor. Inténtalo nuevamente.";
                    });
            });
        })
        .catch(error => {
            console.error('Error al obtener facturas:', error);
        });
}



        function descargarTicketPago(socio, infoPago, idPago) {
            fetch(`/descargarTicket/${socio.id}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ socio, infoPago, idPago }),
            })
                .then(response => response.blob())
                .then(blob => {
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.style.display = 'none';
                    a.href = url;
                    const hoy = new Date();
                    const hoyFormateado = hoy.toLocaleDateString();
                    a.download = `ticket_pago_${socio.id}-${hoyFormateado}.pdf`;
                    document.body.appendChild(a);
                    a.click();
                    window.URL.revokeObjectURL(url);
                })
                .catch((error) => {
                    console.error('Error descargando el ticket:', error);
                });
        }


        function modalListaDeudores() {

            Swal.fire({
                title: 'Seleccionar Mes y Año',
                html: `
                <input type="month" id="mesDeuda" class="swal2-input" required>
            `,
                showCancelButton: true,
                confirmButtonText: 'OK',
                confirmButtonColor: "#4CAF50",
                cancelButtonText: 'Cancelar',
                preConfirm: () => {
                    const mes = document.getElementById('mesDeuda').value;
                    if (!mes) {
                        Swal.showValidationMessage('Por favor selecciona un mes');
                    }
                    return mes;
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    const mesSeleccionado = result.value;
                    window.location.href = `/dashboard/socios/pagos/listadeudores/${mesSeleccionado}`;
                }
            });

        }

        document.getElementById('downloadExcel').addEventListener('click', () => {
            // Hacer una solicitud para obtener el archivo Excel
            fetch('/descargarExcelSocios', {
                method: 'GET',
            })
                .then(response => {
                    if (!response.ok) {
                        throw new Error('Error al descargar el archivo.');
                    }
                    return response.blob(); // Convertir la respuesta a Blob
                })
                .then(blob => {
                    // Crear una URL para el archivo descargado
                    const url = window.URL.createObjectURL(blob);

                    // Crear un elemento <a> para descargar el archivo
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = 'socios.xlsx'; // Nombre del archivo descargado
                    document.body.appendChild(a);
                    a.click(); // Simular un clic para iniciar la descarga
                    document.body.removeChild(a); // Eliminar el elemento después de usarlo
                })
                .catch(error => {
                    console.error('Error al descargar el archivo:', error);
                });
        })

        document.getElementById('downloadPdf').addEventListener('click', async () => {
            try {
                const response = await fetch('/listarPdfSocios', {
                    method: 'GET',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                });

                if (!response.ok) {
                    alert('Error al generar el PDF');
                    return;
                }

                // Crear un blob del PDF y abrirlo en una nueva pestaña
                const blob = await response.blob();
                const url = URL.createObjectURL(blob);
                window.open(url, '_blank');
            } catch (error) {
                console.error('Error al generar el PDF:', error);
                alert('Error inesperado');
            }
        });

        function darDeBajaSocio(id) {
            Swal.fire({
                title: "Estas seguro de dar de baja al socio?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                cancelButtonText: "Cancelar",
                confirmButtonText: "Aceptar"
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch(`/darDeBajaSocio/${id}`, {
                        method: 'PUT',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    }).then((response) => response.json())
                        .then((data) => {
                            if (data.ok) {
                                Swal.fire({
                                    title: "Actualizado!",
                                    text: `${data.message}`,
                                    icon: "success",
                                    showConfirmButton: false,
                                    timer: 2000,
                                    timerProgressBar: true,
                                    didClose: () => {
                                        window.location.reload()
                                    }    
                                })
                            } else {
                                console.error('Response error:', data.message);
                            }
                        })
                        .catch(error => console.error('Error:', error));
                }
            });
        }

