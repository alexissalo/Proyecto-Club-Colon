<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="shortcut icon" href="/public/img/logo_colon_sin_fondo.ico" type="image/x-icon">
    <link rel="stylesheet" href="/public/css/styles.css">
    <title>Socios</title>
    <style>
        td i {
            cursor: pointer;
            margin: 5px;
            padding: 5px;
            border-radius: 10px;
        }

        td i:hover {
            background-color: #ccc;
        }
    </style>
</head>

<body>
    <div class="grid-container">
        <%- include('header') %>
            <%- include('sidebar',{ rolId: rolId,rolNombre:rolNombre, disciplinas:disciplinas }) %>

                <!-- Main -->
                <main class="main-container">
                    <div class="main-title">
                        <h2>SOCIOS</h2>
                    </div>
                    <div class="container-tablas">
                        <div class="tabla-header">
                            <div>
                                <form action="" method="GET" class="search-bar">
                                    <input type="text" name="buscar" class="search-input"
                                        placeholder="Buscar por nombre o DNI..."
                                        value="<%= typeof buscar !== 'undefined' ? buscar : '' %>">
                                    <button type="submit" class="search-button">Buscar</button>
                                </form>
                            </div>
                            <button onclick="añadirSocio()">Nuevo socio</button>
                        </div>
                        <table>
                            <thead>
                                <tr>
                                    <th>Nombre</th>
                                    <th>Dni</th>
                                    <th>Fec.Nac</th>
                                    <th>Telefono</th>
                                    <th>Domicilio</th>
                                    <th>Fec.Inscripcion</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (socios.length> 0) { %>
                                    <% socios.forEach(function(socio) { %>
                                        <tr>
                                            <td>
                                                <%= socio.nombre %>
                                            </td>
                                            <td>
                                                <%= socio.dni %>
                                            </td>
                                            <td>
                                                <%= socio.fechaNacimiento %>
                                            </td>
                                            <td>
                                                <%= socio.telefono %>
                                            </td>
                                            <td>
                                                <%= socio.domicilio %>
                                            </td>
                                            <td>
                                                <%= socio.fechaInscripcion %>
                                            </td>
                                            <td style="text-align: center;">
                                                <i class="bi bi-eye-fill" title="Ver detalles"
                                                    onclick="verDetalle(<%= JSON.stringify(socio) %>)"></i>
                                                <i class="bi bi-pencil-fill" title="Editar"></i>
                                                <i class="bi bi-trash-fill" title="Eliminar" onclick="borrarSocio(<%= socio.id%>)"></i>
                                            </td>
                                        </tr>
                                        <% }); %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="8" style="text-align: center;">No hay socios
                                                        registrados</td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                        <div class="pagination">
                            <div class="pagination-select">
                                Filas por pagina:
                                <select
                                    onchange="window.location.href = '?pagina=1&filasPorPagina=' + this.value + '&buscar=<%= typeof buscar !== 'undefined' ? buscar : '' %>'">
                                    <option value="5" <%=filasPorPagina==5 ? 'selected' : '' %>>5</option>
                                    <option value="10" <%=filasPorPagina==10 ? 'selected' : '' %>>10</option>
                                    <option value="20" <%=filasPorPagina==20 ? 'selected' : '' %>>20</option>
                                </select>
                            </div>
                            <div class="pagination-buttons">
                                <button class="pagination-button" onclick="navigatePage('prev')" <%=pagina===1
                                    ? 'disabled' : '' %>>
                                    <i class="bi bi-chevron-left"></i>
                                </button>
                                <span>
                                    <%= (pagina - 1) * filasPorPagina + 1 %> - <%= Math.min(pagina * filasPorPagina,
                                            totalSocios) %> de <%= totalSocios %>
                                </span>
                                <button class="pagination-button" onclick="navigatePage('next')" <%=pagina>=
                                    Math.ceil(totalSocios / filasPorPagina) ? 'disabled' : '' %>>
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </main>
                <!-- End Main -->
    </div>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/public/js/interacciones.js"></script>
    <script>

        function navigatePage(direction) {
            const paginaActual = <%= pagina %>;
            const filasPorPaginas = <%= filasPorPagina %>;
            const buscar = '<%= typeof buscar !== "undefined" ? buscar : "" %>';
            let nuevaPagina;

            if (direction === 'prev') {
                nuevaPagina = paginaActual - 1;
            } else if (direction === 'next') {
                nuevaPagina = paginaActual + 1;
            }

            window.location.href = `?pagina=${nuevaPagina}&filasPorPagina=${filasPorPaginas}&buscar=${buscar}`;
        }

        function verDetalle(socio) {
            const contenido = `
                <p>Nombre: ${socio.nombre}</p>
                <p>DNI: ${socio.dni}</p>
                <p>Telefono: ${socio.telefono}</p>
                <p>Domicilio: ${socio.domicilio}</p>
                <p>Fecha de nacimiento: ${socio.fechaNacimiento}</p>
                <p>Fecha de inscripcion: ${socio.fechaInscripcion}</p>
                <h2>Pagos de la cuota</h2>
                <table style="margin: 0 auto; height: 60px; overflow-y: auto; display:inline-block;">
                <thead>
                    <tr>
                    <th>Fecha de pago</th>
                    <th>Monto</th>
                    </tr>
                </thead>
                <tbody>
                    ${socio.pagos && socio.pagos.length > 0 ? socio.pagos.map((pago) => `
                    <tr>
                        <td>${pago.fecha}</td>
                        <td>$${pago.valor}</td>
                    </tr>
                    `).join('')
                    : `
                    <tr>
                        <td colspan="2">Sin Pagos registrados</td>
                    </tr>`
                }
                </tbody>
                </table>
            `;

            // Muestra el modal con SweetAlert
            Swal.fire({
                title: 'Detalle del socio',
                html: contenido,
                confirmButtonText: 'Cerrar',
            });
        }

        function añadirSocio() {
            swal({
                title: 'Agregar nuevo socio',
                html: `
                    <form>
                    <div class="form-group">
                        <label for="nombre">Nombre:</label>
                        <input type="text" id="nombre" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <label for="telefono">Teléfono:</label>
                        <input type="tel" id="telefono" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <label for="domicilio">Domicilio:</label>
                        <input type="text" id="domicilio" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <label for="dni">DNI:</label>
                        <input type="number" id="dni" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <label for="fechaNacimiento">Fecha de nacimiento:</label>
                        <input type="date" id="fechaNacimiento" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <label for="disciplina">Disciplina:</label>
                        <select id="disciplina" class="form-control" required>
                        <option value="">Seleccione una disciplina</option>
                        <option value="Futbol">Futbol</option>
                        <option value="Basquet">Basquet</option>
                        <option value="Tenis">Tenis</option>
                        <!-- Agrega más opciones según sea necesario -->
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="tipoSocio">Tipo de socio:</label>
                        <select id="tipoSocio" class="form-control" required>
                        <option value="">Seleccione un tipo de socio</option>
                        <option value="Activo">Activo</option>
                        <option value="Pasivo">Pasivo</option>
                        <option value="Honorario">Honorario</option>
                        <!-- Agrega más opciones según sea necesario -->
                        </select>
                    </div>
                    </form>
                `,
                confirmButtonText: 'Agregar',
                showCancelButton: true,
                cancelButtonText: 'Cancelar',
                preConfirm: () => {
                    const nombre = document.getElementById('nombre').value;
                    const telefono = document.getElementById('telefono').value;
                    const domicilio = document.getElementById('domicilio').value;
                    const dni = document.getElementById('dni').value;
                    const fechaNacimiento = document.getElementById('fechaNacimiento').value;
                    const disciplina = document.getElementById('disciplina').value;
                    const tipoSocio = document.getElementById('tipoSocio').value;

                    // Verifica que todos los campos estén completos
                    if (!nombre || !telefono || !domicilio || !dni || !fechaNacimiento || !disciplina || !tipoSocio) {
                        swal.showValidationError('Por favor, complete todos los campos');
                        return false;
                    }

                    // Agrega la lógica para agregar el nuevo socio a la base de datos
                    // Por ejemplo, puedes hacer una petición AJAX a tu API
                    fetch('/api/socios', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({
                            nombre,
                            telefono,
                            domicilio,
                            dni,
                            fechaNacimiento,
                            disciplina,
                            tipoSocio,
                        }),
                    })
                        .then((response) => response.json())
                        .then((data) => {
                            if (data.success) {
                                swal('Socio agregado con éxito!', '', 'success');
                            } else {
                                swal('Error al agregar socio', '', 'error');
                            }
                        })
                        .catch((error) => console.error(error));
                },
            });
        }

        function borrarSocio(id) {
            Swal.fire({
                title: "Estas seguro?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                cancelButtonText: "Cancelar",
                confirmButtonText: "Borrar"
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch(`/borrarSocio/${id}`, {
                        method: 'DELETE',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    }).then((response) => {
                        if (response.ok) {
                            Swal.fire({
                                title: "Borrado!",
                                text: "Tu evento ha sido borrado.",
                                icon: "success"
                            }).then((response) => {
                                if (result.isConfirmed) {
                                    window.location.reload()
                                }
                            })
                        } else {
                            console.error('Response error:', response.status, response.statusText);
                        }
                    })
                        .catch(error => console.error('Error:', error));
                }
            });

        }

    </script>
</body>

</html>