<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/public/css/styles.css">
    <link rel="shortcut icon" href="/public/img/logo_colon_sin_fondo.ico" type="image/x-icon">
    <style>
        .formTipoSocio,
        .formTipoSocioEditar
        {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            padding: 1rem;
        }

        .formTipoSocio label,
        .formTipoSocioEditar label
         {
            font-weight: bold;
            font-size: 1rem;
            color: #333;
        }

        .formTipoSocio input,
        .formTipoSocioEditar input
        {
            width: 100%;
            padding: 0.5rem;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 1rem;
            color: #333;
            background-color: #fff;
        }

        .formTipoSocio button,
        .formTipoSocioEditar button
        {
            padding: 0.75rem 1.5rem;
            background-color: #4CAF50;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 1rem;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

        .formTipoSocio button:hover,
        .formTipoSocioEditar button:hover
        {
            background-color: #45a049;
        }

        .formTipoSocio button:active,
        .formTipoSocioEditar button:active
        {
            background-color: #3e8e41;
        }
    </style>
    <title>Tipos de socios</title>
</head>

<body>
    <div class="grid-container">
        <%- include('header') %>
            <%- include('sidebar',{ rolId: rolId, rolNombre:rolNombre, disciplinas:disciplinas }) %>

                <!-- Main -->
                <main class="main-container">
                    <div class="main-title">
                        <h2>TIPOS DE SOCIOS</h2>
                    </div>
                    <div class="container-tablas">
                        <div class="tabla-header">
                            <button style="padding: 15px;" onclick="añadirTipoSocio()">Nuevo tipo de socio</button>
                        </div>
                        <table>
                            <thead>
                                <tr>
                                    <th>Tipo de socio</th>
                                    <th>Valor de Cuota</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (tiposdesocios.length> 0) { %>
                                    <% tiposdesocios.forEach(function(tiposocio) { %>
                                        <tr>
                                            <td style="width: 800px;">
                                                <%= tiposocio.nombre %>
                                            </td>
                                            <td style="width: 40%;">
                                                <%= tiposocio.valorDeCuota %>
                                            </td>
                                            <td style="width: 10%;">
                                                <i class="bi bi-pencil-fill" title="Editar" onclick="editarTipoSocio(<%= JSON.stringify(tiposocio) %>)"></i>
                                                <i class="bi bi-trash-fill" title="Eliminar" onclick="borrarTipoDeSocio(<%= tiposocio.id%>)"></i>
                                            </td>
                                        </tr>
                                        <% }); %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="8" style="text-align: center;">No hay tipos de socios
                                                        registrados</td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </main>

                <!-- End Main -->
    </div>

    <script src="/public/js/interacciones.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>

        function añadirTipoSocio(){
            Swal.fire({
                title: 'Agregar nuevo tipo de socio',
                html: `
                    <form class="formTipoSocio">
                        <label for="nombre">Nombre:</label>
                        <input type="text" id="nombre" required>
                        <label for="valorcuota">Valor de la cuota:</label>
                        <input type="number" id="valorcuota" required>
                        <button type="submit">Guardar Tipo de Socio</button>
                    </form>
                    <div class="error-message"></div>
                `,
                showConfirmButton: false,
                showCloseButton: true,
                showCancelButton: false,
                allowOutsideClick: false,
            });

            document.querySelector(".formTipoSocio").addEventListener("submit", (e) => {
                e.preventDefault()

                const nombre = document.getElementById('nombre').value;
                const valorCuota= document.getElementById("valorcuota").value;
                const errorMessage = document.querySelector(".error-message");

                fetch('/crearTipoSocio', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        nombre: nombre,
                        valordecuota:valorCuota
                    }),
                })
                    .then((response) => response.json())
                    .then((data) => {
                        console.log(data);
                        errorMessage.textContent = data.message
                        if (data.ok) {
                            Swal.fire({
                                title: "Tipo de socio creado!",
                                text: data.message,
                                icon: "success",
                                confirmButtonColor: "#4CAF50",
                            }).then((response) => {
                                if (response.isConfirmed) {
                                    window.location.reload()
                                }
                            })
                        }
                    })
                    .catch((error) => console.error(error));
            })
        }

        function editarTipoSocio(tiposocio){
            Swal.fire({
                title: 'Editar tipo de socio',
                html: `
                    <form class="formTipoSocioEditar">
                        <label for="nombreEditar">Nombre:</label>
                        <input type="text" id="nombreEditar" value="${tiposocio.nombre}" required>
                        <label for="valorcuotaEditar">Valor de la cuota:</label>
                        <input type="number" id="valorcuotaEditar" value="${tiposocio.valorDeCuota}" required>
                        <button type="submit">Actualizar Tipo de Socio</button>
                    </form>
                    <div class="error-message"></div>
                `,
                showConfirmButton: false,
                showCloseButton: true,
                showCancelButton: false,
                allowOutsideClick: false,
            });

            document.querySelector(".formTipoSocioEditar").addEventListener("submit", (e) => {
                e.preventDefault()

                const nombre = document.getElementById('nombreEditar').value;
                const valorCuota= document.getElementById("valorcuotaEditar").value;
                const errorMessage = document.querySelector(".error-message");

                fetch(`/editarTipoSocio/${tiposocio.id}`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        nombre: nombre,
                        valordecuota:valorCuota
                    }),
                })
                    .then((response) => response.json())
                    .then((data) => {
                        console.log(data);
                        errorMessage.textContent = data.message
                        if (data.ok) {
                            Swal.fire({
                                title: "Tipo de socio actualizado!",
                                text: data.message,
                                icon: "success",
                                confirmButtonColor: "#4CAF50",
                            }).then((response) => {
                                if (response.isConfirmed) {
                                    window.location.reload()
                                }
                            })
                        }
                    })
                    .catch((error) => console.error(error));
            })
        }

        function borrarTipoDeSocio(id) {
            Swal.fire({
                title: "Estas seguro?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                cancelButtonText: "Cancelar",
                confirmButtonText: "Borrar"
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch(`/borrarTipoSocio/${id}`, {
                        method: 'DELETE',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    }).then((response) => {
                        if (response.ok) {
                            Swal.fire({
                                title: "Borrado!",
                                text: "El tipo de socio ha sido borrado.",
                                icon: "success"
                            }).then((response) => {
                                if (result.isConfirmed) {
                                    window.location.reload()
                                }
                            })
                        } else {
                            console.error('Response error:', response.status, response.statusText);
                        }
                    })
                        .catch(error => console.error('Error:', error));
                }
            });
        }
    </script>
</body>

</html>