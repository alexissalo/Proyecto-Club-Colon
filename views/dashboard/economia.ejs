        document.querySelector("#form-movimientos").addEventListener("submit",async (e)=>{
            e.preventDefault()

            const inputMonto=document.querySelector(`#form-movimientos input[name="monto"]`)
            const inputDocumentacion=document.querySelector(`#form-movimientos input[name="documentacion"]`)
            const inputDescripcion=document.querySelector(`#form-movimientos textarea`)
            const tipoMovimiento=document.querySelector("#tipoMovimiento").value

            let fd= new FormData()
            fd.append("monto",inputMonto.value)
            fd.append("documentacion",inputDocumentacion.files[0])
            fd.append("descripcion",inputDescripcion.value)
            fd.append("disciplina",disciplinaActual)
            fd.append("es_ingreso",tipoMovimiento)

            const ajax=await fetch(`/nuevoMovimiento/${disciplinaActual}`,{
                method:"POST",
                body:fd,
            })

            const result = await ajax.json()
            if(result.ok)
            {
                Swal.fire({
                icon: 'success',
                title: 'Movimiento creado',
                text: result.message,
                showConfirmButton: false,
                timer: 2000,
                timerProgressBar: true,
                didClose: () => {
                    window.location.reload();
                }
            });
            }
            else {
                Swal.fire({
                icon: 'error',
                title: 'Error al crear el movimiento',
                text: result.message,
                showConfirmButton: false,
                timer: 2000,
                timerProgressBar: true,
            });
            }
            
        })
