<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/public/css/styles.css">
    <link rel="shortcut icon" href="/public/img/logo_colon_sin_fondo.ico" type="image/x-icon">
    <style>
        .formTipoCuota,
        .formTipoCuotaEditar {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            padding: 1rem;
        }

        .formTipoCuota label,
        .formTipoCuotaEditar label {
            font-weight: bold;
            font-size: 1rem;
            color: #333;
        }

        .formTipoCuota input,
        .formTipoCuotaEditar input {
            width: 100%;
            padding: 0.5rem;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 1rem;
            color: #333;
            background-color: #fff;
        }

        .formTipoCuota button,
        .formTipoCuotaEditar button {
            padding: 0.75rem 1.5rem;
            background-color: #4CAF50;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 1rem;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

        .formTipoCuota button:hover,
        .formTipoCuotaEditar button:hover {
            background-color: #45a049;
        }

        .formTipoCuota button:active,
        .formTipoCuotaEditar button:active {
            background-color: #3e8e41;
        }
    </style>
    <title>Cuotas Deportistas</title>
</head>

<body>
    <div class="grid-container">
        <%- include('header') %>
            <%- include('sidebar',{ rolId: rolId, rolNombre:rolNombre, disciplinas:disciplinas }) %>

                <!-- Main -->
                <main class="main-container">
                    <div class="main-title">
                        <h2>Cuotas de Deportistas</h2>
                    </div>
                    <div class="container-tablas">
                        <div class="tabla-header">
                            <button id="toggleCron"
                                style="padding: 15px; background-color: #db0000; color: black; margin-left: 0;"
                                onclick="toggleCronDeportistas()">Activar Cron</button>
                            <button style="padding: 15px;" onclick="añadirTipoCuota()">Nueva Tipo de Cuota</button>
                        </div>
                        <table>
                            <thead>
                                <tr>
                                    <th>Nombre</th>
                                    <th>Valor de Cuota</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (data.length> 0) { %>
                                    <% data.forEach(function(item) { %>
                                        <tr>
                                            <td style="width: 800px;">
                                                <%= item.nombre %>
                                            </td>
                                            <td style="width: 40%;">
                                                <%= item.valorDeCuota %>
                                            </td>
                                            <td style="width: 10%;">
                                                <i class="bi bi-pencil-fill" title="Editar"
                                                    onclick="editarTipoCuota(<%= JSON.stringify(item) %>)"></i>
                                                <i class="bi bi-trash-fill" title="Eliminar"
                                                    onclick="borrarTipoCuota(<%= item.id%>)"></i>
                                            </td>
                                        </tr>
                                        <% }); %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="8" style="text-align: center;">No hay tipos de cuotas
                                                        registradas</td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </main>

                <!-- End Main -->
    </div>

    <script src="/public/js/interacciones.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const disciplinaActual = "<%= disciplina %>";

        function añadirTipoCuota() {
            Swal.fire({
                title: 'Agregar nueva tipo de cuota',
                html: `
                    <form class="formTipoCuota">
                        <label for="nombre">Nombre:</label>
                        <input type="text" id="nombre" required>
                        <label for="valorcuota">Valor de la cuota:</label>
                        <input type="number" id="valorcuota" required>
                        <button type="submit">Guardar</button>
                    </form>
                    <div class="error-message"></div>
                `,
                showConfirmButton: false,
                showCloseButton: true,
                showCancelButton: false,
                allowOutsideClick: false,
            });

            document.querySelector(".formTipoCuota").addEventListener("submit", (e) => {
                e.preventDefault()

                const nombre = document.getElementById('nombre').value;
                const valorCuota = document.getElementById("valorcuota").value;
                const errorMessage = document.querySelector(".error-message");

                fetch(`/crearTipoCuota/${disciplinaActual}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        nombre: nombre,
                        valordecuota: valorCuota
                    }),
                })
                    .then((response) => response.json())
                    .then((data) => {
                        console.log(data);
                        errorMessage.textContent = data.message
                        if (data.ok) {
                            Swal.fire({
                                title: "Tipo de cuota creada!",
                                text: data.message,
                                icon: "success",
                                confirmButtonColor: "#4CAF50",
                            }).then((response) => {
                                if (response.isConfirmed) {
                                    window.location.reload()
                                }
                            })
                        }
                    })
                    .catch((error) => console.error(error));
            })
        }

        function editarTipoCuota(tipocuota) {
            Swal.fire({
                title: 'Editar tipo de cuota',
                html: `
                    <form class="formTipoCuotaEditar">
                        <label for="nombreEditar">Nombre:</label>
                        <input type="text" id="nombreEditar" value="${tipocuota.nombre}" required>
                        <label for="valorcuotaEditar">Valor de la cuota:</label>
                        <input type="number" id="valorcuotaEditar" value="${tipocuota.valorDeCuota}" required>
                        <button type="submit">Actualizar</button>
                    </form>
                    <div class="error-message"></div>
                `,
                showConfirmButton: false,
                showCloseButton: true,
                showCancelButton: false,
                allowOutsideClick: false,
            });

            document.querySelector(".formTipoCuotaEditar").addEventListener("submit", (e) => {
                e.preventDefault()

                const nombre = document.getElementById('nombreEditar').value;
                const valorCuota = document.getElementById("valorcuotaEditar").value;
                const errorMessage = document.querySelector(".error-message");

                fetch(`/editarTipoCuota/${disciplinaActual}/${tipocuota.id}`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        nombre: nombre,
                        valordecuota: valorCuota
                    }),
                })
                    .then((response) => response.json())
                    .then((data) => {
                        console.log(data);
                        errorMessage.textContent = data.message
                        if (data.ok) {
                            Swal.fire({
                                title: "Tipo de cuota actualizada!",
                                text: data.message,
                                icon: "success",
                                confirmButtonColor: "#4CAF50",
                            }).then((response) => {
                                if (response.isConfirmed) {
                                    window.location.reload()
                                }
                            })
                        }
                    })
                    .catch((error) => console.error(error));
            })
        }

        function borrarTipoCuota(id) {
            Swal.fire({
                title: "Estas seguro?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                cancelButtonText: "Cancelar",
                confirmButtonText: "Borrar"
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch(`/borrarTipoCuota/${disciplinaActual}/${id}`, {
                        method: 'DELETE',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    }).then((response) => {
                        if (response.ok) {
                            Swal.fire({
                                title: "Borrado!",
                                text: "El tipo de cuota ha sido borrado.",
                                icon: "success"
                            }).then((response) => {
                                if (result.isConfirmed) {
                                    window.location.reload()
                                }
                            })
                        } else {
                            console.error('Response error:', response.status, response.statusText);
                        }
                    })
                        .catch(error => console.error('Error:', error));
                }
            });
        }

        let cronActivo = false; // Estado inicial del cron (puedes inicializarlo según tu lógica en el backend).


        function toggleCronDeportistas() {
            const mensajeConfirmacion = cronActivo
                ? '¿Estás seguro de que deseas desactivar la facturacion automatica?'
                : '¿Estás seguro de que deseas activar la facturacion automatica?';

            Swal.fire({
                title: 'Confirmar acción',
                text: mensajeConfirmacion,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: cronActivo ? 'Desactivar' : 'Activar',
                cancelButtonText: 'Cancelar',
            }).then((result) => {
                if (result.isConfirmed) {
                    const endpoint = cronActivo
                        ? '/cron/desactivar-deportistas'
                        : '/cron/activar-deportistas';

                    fetch(endpoint, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                    })
                        .then((response) => response.json())
                        .then((data) => {
                            Swal.fire({
                                title: cronActivo ? 'Facturacion automatica desactivada' : 'Facturacion automatica activada',
                                text: data.message,
                                icon: 'success',
                                showConfirmButton: false,
                                timer: 2000,
                                timerProgressBar: true,
                                didClose: () => {
                                    cronActivo = !cronActivo; // Cambia el estado del cron.
                                    actualizarBotonToggle();
                                    window.location.reload()
                                }
                            });
                        })
                        .catch((error) => {
                            console.error('Error:', error);
                            Swal.fire({
                                title: 'Error',
                                text: 'Hubo un problema al cambiar el estado de la facturacion automatica.',
                                icon: 'error',
                            });
                        });
                }
            });
        }


        function actualizarBotonToggle() {
            const boton = document.getElementById('toggleCron');
            if (cronActivo) {
                boton.textContent = 'Desactivar Facturacion Automatica';
                boton.style.backgroundColor = '##db0000'; // Cambia el color del botón a un tono desactivado.
            } else {
                boton.textContent = 'Activar Facturacion Automatica';
                boton.style.backgroundColor = '#4CAF50'; // Cambia el color del botón a un tono activado.
            }
        }

        // Llamar al servidor para verificar el estado inicial del cron.
        document.addEventListener('DOMContentLoaded', () => {
            fetch('/cron/estado-deportistas-cron', {
                method: 'GET',
                headers: {
                    'Content-Type': 'application/json',
                },
            })
                .then((response) => response.json())
                .then((data) => {
                    cronActivo = data.activo;
                    actualizarBotonToggle();
                })
                .catch((error) => console.error('Error al obtener el estado del cron:', error));
        });
    </script>
</body>

</html>