<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="shortcut icon" href="/public/img/logo_colon_sin_fondo.ico" type="image/x-icon">
    <link rel="stylesheet" href="/public/css/styles.css">
    <style>
        #usuarioForm {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            padding: 1rem;

            border-radius: 8px;

        }

        #usuarioForm label {
            font-weight: bold;
            font-size: 1rem;
            color: #333;
        }

        #usuarioForm input[type="text"],
        #usuarioForm input[type="email"],
        #usuarioForm select,
        #usuarioForm textarea {
            width: 100%;
            padding: 0.5rem;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 1rem;
            color: #333;
            background-color: #fff;
        }

        #usuarioForm textarea {
            resize: none;
            min-height: 100px;
        }

        #usuarioForm button {
            padding: 0.75rem 1.5rem;
            background-color: #4CAF50;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 1rem;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

        #usuarioForm button:hover {
            background-color: #45a049;
        }

        #usuarioForm button:active {
            background-color: #3e8e41;
        }
    </style>
    <title>Usuarios</title>
</head>

<body>
    <div class="grid-container">
        <%- include('header') %>
            <%- include('sidebar',{ rolId: rolId,rolNombre:rolNombre, disciplinas:disciplinas }) %>
                <main class="main-container">
                    <div class="main-title">
                        <h2>USUARIOS</h2>
                    </div>
                    <div class="container-tablas">
                        <div class="tabla-header">
                            <div>
                                <form action="" method="GET" class="search-bar">
                                    <input type="text" name="buscar" class="search-input"
                                        placeholder="Buscar por nombre"
                                        value="<%= typeof buscar !== 'undefined' ? buscar : '' %>">
                                    <button type="submit" class="search-button">Buscar</button>
                                </form>
                            </div>
                            <button class="añadir-usuario">Nuevo usuario</button>
                        </div>
                        <table>
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Nombre</th>
                                    <th>Email</th>
                                    <th>Rol</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (usuarios.length> 0) { %>
                                    <% usuarios.forEach(function(usuario) { %>
                                        <tr>
                                            <td>
                                                <%= usuario.id %>
                                            </td>
                                            <td>
                                                <%= usuario.nombre %>
                                            </td>
                                            <td>
                                                <%= usuario.email %>
                                            </td>
                                            <td>
                                                <%= usuario.rol_nombre %>
                                            </td>
                                            <td>
                                                <i class="bi bi-trash-fill" title="Eliminar"
                                                    onclick="borrarUsuario(<%=usuario.id%>)"></i>
                                            </td>
                                        </tr>
                                        <% }); %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="5" style="text-align: center;">No hay usuarios
                                                        registrados</td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                        <div class="pagination">
                            <div class="pagination-select">
                                Filas por pagina:
                                <select
                                    onchange="window.location.href = '?pagina=1&filasPorPagina=' + this.value + '&buscar=<%= typeof buscar !== 'undefined' ? buscar : '' %>'">
                                    <option value="5" <%=filasPorPagina==5 ? 'selected' : '' %>>5</option>
                                    <option value="10" <%=filasPorPagina==10 ? 'selected' : '' %>>10</option>
                                    <option value="20" <%=filasPorPagina==20 ? 'selected' : '' %>>20</option>
                                </select>
                            </div>
                            <div class="pagination-buttons">
                                <button class="pagination-button" onclick="navigatePage('prev')" <%=pagina===1
                                    ? 'disabled' : '' %>>
                                    <i class="bi bi-chevron-left"></i>
                                </button>
                                <span>
                                    <%= (pagina - 1) * filasPorPagina + 1 %> - <%= Math.min(pagina * filasPorPagina,
                                            totalUsuarios) %> de <%= totalUsuarios %>
                                </span>
                                <button class="pagination-button" onclick="navigatePage('next')" <%=pagina>=
                                    Math.ceil(totalUsuarios / filasPorPagina) ? 'disabled' : '' %>>
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/public/js/interacciones.js"></script>
    <script>

        const rolesData = <%- JSON.stringify(roles) %>;

        function navigatePage(direction) {
            const paginaActual = <%= pagina %>;
            const filasPorPaginas = <%= filasPorPagina %>;
            const buscar = '<%= typeof buscar !== "undefined" ? buscar : "" %>';
            let nuevaPagina;

            if (direction === 'prev') {
                nuevaPagina = paginaActual - 1;
            } else if (direction === 'next') {
                nuevaPagina = paginaActual + 1;
            }

            window.location.href = `?pagina=${nuevaPagina}&filasPorPagina=${filasPorPaginas}&buscar=${buscar}`;
        }

        const botonAñadir = document.querySelector(".añadir-usuario").addEventListener("click", crearUsuario)

        function crearUsuario() {
            const rolesHtml = rolesData.map((rol) => {
                return `<option value="${rol.id}">${rol.nombre}</option>`;
            }).join('');
            Swal.fire({
                html: `
                        <h2>Crear Usuarios</h2>
                        <form id="usuarioForm">
                            <label for="title">Nombre:</label>
                            <input type="text" id="nombre" required>

                            <label for="start">Email:</label>
                            <input type="email" id="email" required>

                            <label for="end">Rol:</label>
                            <select id="rol">
                                ${rolesHtml}
                            </select>
                            <button>Guardar Usuario</button>
                        </form>
                        <div class="error-message"></div>
                    `,
                showCloseButton: true,
                focusConfirm: false,
                showConfirmButton: false,
            });

            document.getElementById('usuarioForm').addEventListener('submit', añadirUsuario);
        }

        function añadirUsuario(e) {
            e.preventDefault();
            const nombre = document.getElementById("nombre").value;
            const email = document.getElementById("email").value;
            const rol = document.getElementById("rol").value;
            const errorMessage = document.querySelector(".error-message");

            console.log(rol);


            const usuarioData = {
                nombre: nombre,
                email: email,
                id_rol: rol,
            };


            fetch('/crearUsuario', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(usuarioData)
            }).then((response) => response.json())
                .then((data) => {
                    if (data.ok) {
                        Swal.fire({
                            title: "Usuario creado!",
                            text: data.message,
                            icon: "success",
                            confirmButtonColor: "#4CAF50",
                        }).then((response) => {
                            if (response.isConfirmed) {
                                window.location.reload()
                            }
                        })
                    } else {
                        errorMessage.textContent = data.message
                    }
                })
                .catch(error => console.error('Error:', error));
        }

        function borrarUsuario(id) {
            Swal.fire({
                title: "Estas seguro?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                cancelButtonText: "Cancelar",
                confirmButtonText: "Borrar"
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch(`/borrarUsuario/${id}`, {
                        method: 'DELETE',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    }).then((response) => response.json())
                        .then((data) => {
                            if (data.ok) {
                                Swal.fire({
                                    title: "Borrado!",
                                    text: `${data.message}`,
                                    icon: "success"
                                }).then((response) => {
                                    if (result.isConfirmed) {
                                        window.location.reload()
                                    }
                                })
                            } else {
                                console.error('Response error:', data.message);
                            }
                        })
                        .catch(error => console.error('Error:', error));
                }
            });
        }

    </script>
</body>

</html>