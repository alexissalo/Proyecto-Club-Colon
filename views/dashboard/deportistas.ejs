<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="shortcut icon" href="/public/img/logo_colon_sin_fondo.ico" type="image/x-icon">
    <link rel="stylesheet" href="/public/css/styles.css">
    <style>
    </style>
    <title>Deportistas</title>
</head>

<body>
    <div class="grid-container">
        <%- include('header') %>
            <%- include('sidebar',{ rolId: rolId, rolNombre:rolNombre, disciplinas:disciplinas }) %>

                <!-- Main -->
                <main class="main-container">
                    <div class="main-title">
                        <h2>DEPORTISTAS</h2>
                    </div>
                    <div class="container-tablas">
                        <div class="tabla-header">
                            <div>
                                <form action="" method="GET" class="search-bar">
                                    <input type="text" name="buscar" class="search-input"
                                        placeholder="Buscar por nombre"
                                        value="<%= typeof buscar !== 'undefined' ? buscar : '' %>">
                                    <button type="submit" class="search-button">Buscar</button>
                                </form>
                            </div>
                        </div>
                        <table>
                            <thead>
                                <tr>
                                    <th>Nombre Completo</th>
                                    <th>Fecha de Nacimiento</th>
                                    <th>Domicilio</th>
                                    <th>Localidad</th>
                                    <th>Altura</th>
                                    <th>Peso</th>
                                    <th>Talle Calzado</th>
                                    <th>Talle Camiseta</th>
                                    <th>Talle Pantalon</th>
                                    <th>Tel. Jugador</th>
                                    <th>Tel. Emergencia</th>
                                    <th>Grupo Sanguíneo</th>
                                    <th>Factor</th>
                                    <th>Cobertura Médica</th>
                                    <th>Número Afiliado</th>
                                    <th>Lesiones</th>
                                    <th>Alergias</th>
                                    <th>Patologías</th>
                                    <th>Tratamientos</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (deportistas.length> 0) { %>
                                    <% deportistas.forEach(function(deportista) { %>
                                        <tr>
                                            <td>
                                                <%= deportista.nombre %>
                                            </td>
                                            <td>
                                                <%= deportista.fechaNacimiento %>
                                            </td>
                                            <td>
                                                <%= deportista.domicilio %>
                                            </td>
                                            <td>
                                                <%= deportista.localidad %>
                                            </td>
                                            <td>
                                                <%= deportista.altura %>
                                            </td>
                                            <td>
                                                <%= deportista.peso %>
                                            </td>
                                            <td>
                                                <%= deportista.talleCalzado %>
                                            </td>
                                            <td>
                                                <%= deportista.talleCamiseta %>
                                            </td>
                                            <td>
                                                <%= deportista.tallePantalon %>
                                            </td>
                                            <td>
                                                <%= deportista.telefonoJugador %>
                                            </td>
                                            <td>
                                                <%= deportista.telefonoEmergencia %>
                                            </td>
                                            <td>
                                                <%= deportista.grupoSanguineo %>
                                            </td>
                                            <td>
                                                <%= deportista.factor %>
                                            </td>
                                            <td>
                                                <%= deportista.coberturaMedica %>
                                            </td>
                                            <td>
                                                <%= deportista.numeroAfiliado %>
                                            </td>
                                            <td>
                                                <%= deportista.lesiones %>
                                            </td>
                                            <td>
                                                <%= deportista.alergias %>
                                            </td>
                                            <td>
                                                <%= deportista.patologias %>
                                            </td>
                                            <td>
                                                <%= deportista.tratamientos %>
                                            </td>
                                            <td style="text-align: center;">
                                                <i class="bi bi-eye-fill" title="Ver detalles"
                                                    onclick="verDetalle(<%= JSON.stringify(deportista) %>)"></i>
                                                <i class="bi bi-pencil-fill" title="Editar"></i>
                                                <i class="bi bi-trash-fill" title="Eliminar"
                                                    onclick="borrarDeportista(<%= deportista.id %>)"></i>
                                            </td>
                                        </tr>
                                        <% }); %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="21" style="text-align: center;">No hay deportistas
                                                        registrados</td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                        <div class="pagination">
                            <div class="pagination-select">
                                Filas por pagina:
                                <select
                                    onchange="window.location.href = '?pagina=1&filasPorPagina=' + this.value + '&buscar=<%= typeof buscar !== 'undefined' ? buscar : '' %>'">
                                    <option value="5" <%=filasPorPagina==5 ? 'selected' : '' %>>5</option>
                                    <option value="10" <%=filasPorPagina==10 ? 'selected' : '' %>>10</option>
                                    <option value="20" <%=filasPorPagina==20 ? 'selected' : '' %>>20</option>
                                </select>
                            </div>
                            <div class="pagination-buttons">
                                <button class="pagination-button" onclick="navigatePage('prev')" <%=pagina===1
                                    ? 'disabled' : '' %>>
                                    <i class="bi bi-chevron-left"></i>
                                </button>
                                <span>
                                    <%= (pagina - 1) * filasPorPagina + 1 %> - <%= Math.min(pagina * filasPorPagina,
                                            totalDeportistas) %> de <%= totalDeportistas %>
                                </span>
                                <button class="pagination-button" onclick="navigatePage('next')" <%=pagina>=
                                    Math.ceil(totalDeportistas / filasPorPagina) ? 'disabled' : '' %>>
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </main>
                <!-- End Main -->
    </div>

    <script src="/public/js/interacciones.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>

        function borrarDeportista(id) {
            Swal.fire({
                title: "Estas seguro?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                cancelButtonText: "Cancelar",
                confirmButtonText: "Borrar"
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch(`/borrarSocio/${id}`, {
                        method: 'DELETE',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    }).then((response) => {
                        if (response.ok) {
                            Swal.fire({
                                title: "Borrado!",
                                text: "El deportista ha sido borrado.",
                                icon: "success"
                            }).then((response) => {
                                if (result.isConfirmed) {
                                    window.location.reload()
                                }
                            })
                        } else {
                            console.error('Response error:', response.status, response.statusText);
                        }
                    })
                        .catch(error => console.error('Error:', error));
                }
            });
        }
    </script>
</body>

</html>