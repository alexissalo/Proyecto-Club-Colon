<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="shortcut icon" href="/public/img/logo_colon_sin_fondo.ico" type="image/x-icon">
    <link rel="stylesheet" href="/public/css/styles.css">
    <style>
        .formDeportistaPago {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            padding: 1rem;
        }

        .formDeportistaPago label {
            font-weight: bold;
            font-size: 1rem;
            color: #333;
        }

        .formDeportistaPago input,
        .formDeportistaPago select {
            width: 100%;
            padding: 0.5rem;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 1rem;
            color: #333;
            background-color: #fff;
        }

        .formDeportistaPago button {
            padding: 0.75rem 1.5rem;
            background-color: #4CAF50;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 1rem;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

        .formDeportistaPago button:hover {
            background-color: #45a049;
        }

        .formDeportistaPago button:active {
            background-color: #3e8e41;
        }

        .botonlistadodeudores {
            background-color: #2889dd;
            color: white;
            font-weight: 500;
            border: none;
            margin: 10px 10px 10px 0px;
            padding: 10px;
            border-radius: 5px;
            cursor: pointer;
        }

        .botonlistadodeudores:hover {
            background-color: #2772b3;
        }
    </style>
    <title>Deportistas de <%= disciplina %>
    </title>
</head>

<body>
    <div class="grid-container">
        <%- include('header') %>
            <%- include('sidebar',{ rolId: rolId, rolNombre:rolNombre, disciplinas:disciplinas }) %>

                <!-- Main -->
                <main class="main-container">
                    <div class="main-title">
                        <h2>DEPORTISTAS DE <%= disciplina.toUpperCase() %>
                        </h2>
                    </div>
                    <div class="container-tablas">
                        <div class="tabla-header">
                            <div>
                                <form action="" method="GET" class="search-bar">
                                    <input type="text" name="buscar" class="search-input"
                                        placeholder="Buscar por nombre o DNI..."
                                        value="<%= typeof buscar !== 'undefined' ? buscar : '' %>">
                                    <button type="submit" class="search-button">Buscar</button>
                                </form>
                            </div>
                        </div>
                        <table>
                            <thead>
                                <tr>
                                    <th>Nombre Completo</th>
                                    <th>DNI</th>
                                    <th>Fecha de Nacimiento</th>
                                    <th>Domicilio</th>
                                    <th>Localidad</th>
                                    <th>Es Socio?</th>
                                    <th>Tipo de Cuota</th>
                                    <% if (disciplina=="futbol" ) { %>
                                        <th>Categoria</th>
                                        <% } %>
                                            <th>Email</th>
                                            <th>Tel. Jugador</th>
                                            <th>Tel. Emergencia</th>
                                            <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (deportistas.length> 0) { %>
                                    <% deportistas.forEach(function(deportista) { %>
                                        <tr>
                                            <td>
                                                <%= deportista.nombre %>
                                            </td>
                                            <td>
                                                <%= deportista.dni %>
                                            </td>
                                            <td>
                                                <%= deportista.fechaNacimiento %>
                                            </td>
                                            <td>
                                                <%= deportista.domicilio %>
                                            </td>
                                            <td>
                                                <%= deportista.localidad %>
                                            </td>
                                            <td>
                                                <% if (deportista.esSocio) { %>
                                                    Si
                                                <% }else{ %>
                                                    No
                                                <% } %>
                                            </td>
                                            <td style="text-transform: capitalize;">
                                                <%= deportista.tipodecuotanombre %>
                                            </td>
                                            <% if (disciplina=="futbol" ) { %>
                                                <td>
                                                    <%= deportista.categoria %>
                                                </td>
                                                <% } %>
                                                    <td>
                                                        <%= deportista.email %>
                                                    </td>
                                                    <td>
                                                        <%= deportista.telefonoJugador %>
                                                    </td>
                                                    <td>
                                                        <%= deportista.telefonoEmergencia %>
                                                    </td>
                                                    <td style="text-align: center;">
                                                        <i class="bi bi-eye-fill" title="Ver detalles"
                                                            onclick="verDetalle(<%= JSON.stringify(deportista) %>)"></i>
                                                        <i class="bi bi-clipboard"
                                                            onclick="window.location.href=`/dashboard/deportistas/<%= disciplina %>/pagos/<%= deportista.id %>`"
                                                            title="Ver Pagos"></i>
                                                        <i class="bi bi-cash" title="Crear pagos"
                                                            onclick="crearPago(<%= JSON.stringify(deportista) %>)">
                                                        </i>
                                                        <i class="bi bi-pencil-fill" title="Editar"
                                                            onclick="window.location.href='/dashboard/editardeportista/<%= disciplina %>/<%= deportista.id %>'">
                                                        </i>
                                                        <i class="bi bi-trash-fill" title="Eliminar"
                                                            onclick="borrarDeportista(<%= deportista.id %>)"></i>
                                                    </td>
                                        </tr>
                                        <% }); %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="21" style="text-align: center;">No hay deportistas
                                                        registrados</td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                        <div class="pagination">
                            <div class="pagination-select">
                                Filas por pagina:
                                <select
                                    onchange="window.location.href = '?pagina=1&filasPorPagina=' + this.value + '&buscar=<%= typeof buscar !== 'undefined' ? buscar : '' %>'">
                                    <option value="5" <%=filasPorPagina==5 ? 'selected' : '' %>>5</option>
                                    <option value="10" <%=filasPorPagina==10 ? 'selected' : '' %>>10</option>
                                    <option value="20" <%=filasPorPagina==20 ? 'selected' : '' %>>20</option>
                                </select>
                            </div>
                            <div class="pagination-buttons">
                                <button class="pagination-button" onclick="navigatePage('prev')" <%=pagina===1
                                    ? 'disabled' : '' %>>
                                    <i class="bi bi-chevron-left"></i>
                                </button>
                                <span>
                                    <%= (pagina - 1) * filasPorPagina + 1 %> - <%= Math.min(pagina * filasPorPagina,
                                            totalDeportistas) %> de <%= totalDeportistas %>
                                </span>
                                <button class="pagination-button" onclick="navigatePage('next')" <%=pagina>=
                                    Math.ceil(totalDeportistas / filasPorPagina) ? 'disabled' : '' %>>
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </div>
                        </div><button onclick="modalListaDeudores()" class="botonlistadodeudores">Listado
                            de deudores</button>

                    </div>
                </main>
                <!-- End Main -->
    </div>

    <script src="/public/js/interacciones.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const disciplinaActual = "<%= disciplina %>";

        function navigatePage(direction) {
            const paginaActual = <%= pagina %>;
            const filasPorPaginas = <%= filasPorPagina %>;
            const buscar = '<%= typeof buscar !== "undefined" ? buscar : "" %>';
            let nuevaPagina;

            if (direction === 'prev') {
                nuevaPagina = paginaActual - 1;
            } else if (direction === 'next') {
                nuevaPagina = paginaActual + 1;
            }

            window.location.href = `?pagina=${nuevaPagina}&filasPorPagina=${filasPorPaginas}&buscar=${buscar}`;
        }

        function borrarDeportista(id) {
            Swal.fire({
                title: "Estas seguro?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                cancelButtonText: "Cancelar",
                confirmButtonText: "Borrar"
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch(`/borrarDeportista/${id}`, {
                        method: 'DELETE',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    }).then((response) => {
                        if (response.ok) {
                            Swal.fire({
                                title: "Borrado!",
                                text: "El deportista ha sido borrado.",
                                icon: "success"
                            }).then((response) => {
                                if (result.isConfirmed) {
                                    window.location.reload()
                                }
                            })
                        } else {
                            console.error('Response error:', response.status, response.statusText);
                        }
                    })
                        .catch(error => console.error('Error:', error));
                }
            });
        }

        function crearPago(deportista) {
            // Solicitar las facturas impagas del socio
            fetch(`/listarFacturasImpagas/${disciplinaActual}/${deportista.id}`)
                .then(response => response.json())
                .then(res => {
                    if (!res.ok) {
                        console.error('Error al obtener facturas:', res.message);
                        return;
                    }

                    const facturas = res.data; // Array de facturas impagas
                    const facturasHtml = `
            <div class="container-tablas">
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Monto</th>
                            <th>Fecha de Emision</th>
                            <th>Seleccionar</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${facturas && facturas.length > 0 ? facturas.map(factura => `
                        <tr>
                            <td>${factura.id}</td>
                            <td class="monto">$${factura.monto}</td>
                            <td>${factura.fecha_emision}</td>
                            <td>
                                <input type="checkbox" class="factura-checkbox" data-monto="${factura.monto}" value="${factura.id}">
                            </td>
                        </tr>`).join('') :
                            `
                        <tr>
                            <td colspan="4" style="padding: 10px; text-align: center;">No se encuentran facturas</td>
                        </tr>
                        `}
                    </tbody>
                </table>
            </div>
            `;

                    // Mostrar el modal con las facturas
                    Swal.fire({
                        title: 'Crear pago',
                        html: `
                <form class="formDeportistaPago">
                    <div>
                        <h4>Selecciona las facturas a pagar:</h4>
                        ${facturasHtml}
                    </div>
                    <div id="monto-total" style="margin-top: 10px; font-weight: bold;">Monto total: $0</div>
                    <label>Método de pago:</label>
                    <select required>
                        <option value="Efectivo">Efectivo</option>
                        <option value="Transferencia">Transferencia</option>
                    </select>
                    <button type="submit">Guardar Pago</button>
                </form>
                <div class="error-message" style="color: red; margin-top: 10px;"></div>
                `,
                        showConfirmButton: false,
                        showCloseButton: true,
                        allowOutsideClick: false,
                    });

                    // Actualizar el monto total cuando cambian las selecciones
                    const checkboxes = document.querySelectorAll(".factura-checkbox");
                    const totalDisplay = document.querySelector("#monto-total");

                    checkboxes.forEach(checkbox => {
                        checkbox.addEventListener("change", () => {
                            const total = Array.from(checkboxes)
                                .filter(cb => cb.checked)
                                .reduce((sum, cb) => sum + parseFloat(cb.dataset.monto), 0);

                            totalDisplay.textContent = `Monto total: $${total.toFixed(2)}`;
                        });
                    });

                    // Manejar el envío del formulario
                    document.querySelector(".formDeportistaPago").addEventListener("submit", (e) => {
                        e.preventDefault();

                        // Recoger las facturas seleccionadas
                        const facturasSeleccionadas = Array.from(document.querySelectorAll(".factura-checkbox:checked"))
                            .map(checkbox => checkbox.value);

                        if (facturasSeleccionadas.length === 0) {
                            const errorMessage = document.querySelector(".error-message");
                            errorMessage.textContent = "Debes seleccionar al menos una factura.";
                            return;
                        }

                        const metodoDePago = document.querySelector(".formDeportistaPago select").value;

                        const infoPago = {
                            id_deportista: deportista.id,
                            facturas: facturasSeleccionadas,
                            metodoPago: metodoDePago,
                            monto: parseFloat(totalDisplay.textContent.replace("Monto total: $", "")),
                        };

                        // Enviar los datos al servidor
                        fetch(`/crearPagoDeportista`, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                            },
                            body: JSON.stringify(infoPago),
                        })
                            .then((response) => response.json())
                            .then((data) => {
                                if (data.ok) {
                                    Swal.fire({
                                        title: "Pago registrado",
                                        text: "El pago fue registrado exitosamente.",
                                        icon: "success",
                                    }).then(() => {
                                        window.location.reload();
                                    });
                                } else {
                                    const errorMessage = document.querySelector(".error-message");
                                    errorMessage.textContent = data.message || "Error al registrar el pago.";
                                }
                            })
                            .catch((error) => {
                                console.error('Error:', error);
                                const errorMessage = document.querySelector(".error-message");
                                errorMessage.textContent = "Error en el servidor. Inténtalo nuevamente.";
                            });
                    });
                })
                .catch(error => {
                    console.error('Error al obtener facturas:', error);
                });
        }

        function descargarTicketPago(deportista, infoPago, idPago) {
            fetch(`/descargarTicketDeportista/${deportista.id}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ deportista, infoPago, idPago }),
            })
                .then(response => response.blob())
                .then(blob => {
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.style.display = 'none';
                    a.href = url;
                    const hoy = new Date();
                    const hoyFormateado = hoy.toLocaleDateString();
                    a.download = `ticket_pago_${deportista.id}-${hoyFormateado}.pdf`;
                    document.body.appendChild(a);
                    a.click();
                    window.URL.revokeObjectURL(url);
                })
                .catch((error) => {
                    console.error('Error descargando el ticket:', error);
                });
        }


        function verDetalle(deportista) {
            Swal.fire({
                title: 'Selecciona la sección de datos',
                input: 'select',
                inputOptions: {
                    personales: 'Datos Personales',
                    comunicacion: 'Comunicación',
                    medicos: 'Datos Médicos',
                    talles: 'Talles',
                    familiares: 'Datos Familiares',
                },
                inputPlaceholder: 'Seleccionar',
                showCancelButton: true,
                confirmButtonText: 'Ver Datos',
                confirmButtonColor: "#3e8e41",
                cancelButtonColor: "#d33",
                cancelButtonText: 'Cancelar',
                inputValidator: (value) => {
                    if (!value) {
                        return 'Por favor, selecciona una opción';
                    }
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    // Según la selección, se renderizan los datos correspondientes
                    let selectedData = result.value;
                    renderData(selectedData, deportista);
                }
            });
        }

        function renderData(section, deportista) {
            let dataHtml = '';

            switch (section) {
                case 'personales':
                    dataHtml = `
                        <ul>
                            <li><strong>Nombre:</strong> ${deportista.nombre || "Dato no registrado"}</li>
                            <li><strong>DNI:</strong> ${deportista.dni || "Dato no registrado"}</li>
                            <li><strong>Fecha de Nacimiento:</strong> ${deportista.fechaNacimiento || "Dato no registrado"}</li>
                            <li><strong>Domicilio:</strong> ${deportista.domicilio || "Dato no registrado"}</li>
                            <li><strong>Escolaridad:</strong> ${deportista.escolaridad || "Dato no registrado"}</li>
                            <li><strong>Grado Escolar:</strong> ${deportista.gradoEscolar || "Dato no registrado"}</li>
                            <li><strong>Altura:</strong> ${deportista.altura || "Dato no registrado"}</li>
                            <li><strong>Peso:</strong> ${deportista.peso || "Dato no registrado"}</li>
                            <li><strong>Altura:</strong> ${deportista.altura || "Dato no registrado"}</li>
                        </ul>`;
                    break;

                case 'medicos':
                    dataHtml = `
                        <ul>
                            <li><strong>Grupo Sanguíneo:</strong> ${deportista.grupoSanguineo || "Dato no registrado"}</li>
                            <li><strong>Factor:</strong> ${deportista.factor || "Dato no registrado"}</li>
                            <li><strong>Cobertura Medica:</strong> ${deportista.coberturaMedica || "Dato no registrado"}</li>
                            <li><strong>Numero de afiliado:</strong> ${deportista.numeroAfiliado || "Dato no registrado"}</li>
                            <li><strong>Alergias:</strong> ${deportista.alergias || "Dato no registrado"}</li>
                            <li><strong>Lesiones:</strong> ${deportista.lesiones || "Dato no registrado"}</li>
                            <li><strong>Patologias:</strong> ${deportista.patologias || "Dato no registrado"}</li>
                            <li><strong>Tratamientos:</strong> ${deportista.tratamientos || "Dato no registrado"}</li>
                        </ul>`;
                    break;

                case 'talles':
                    dataHtml = `
                        <ul>
                            <li><strong>Talle de Calzado:</strong> ${deportista.talleCalzado || "Dato no registrado"}</li>
                            <li><strong>Talle de Camiseta:</strong> ${deportista.talleCamiseta || "Dato no registrado"}</li>
                            <li><strong>Talle de Pantalón:</strong> ${deportista.tallePantalon || "Dato no registrado"}</li>
                        </ul>`;
                    break;

                case 'familiares':
                    dataHtml = `
                        <ul>
                            <li><strong>Nombre del Familiar:</strong> ${deportista.tutorNombre || "Dato no registrado"}</li>
                            <li><strong>Domicilio del Familiar:</strong> ${deportista.domicilioTutor || "Dato no registrado"}</li>
                            <li><strong>Localidad del Familiar:</strong> ${deportista.localidadTutor || "Dato no registrado"}</li>
                            <li><strong>Localidad del Familiar:</strong> ${deportista.localidadTutor || "Dato no registrado"}</li>
                            <li><strong>Telefono del Familiar:</strong> ${deportista.telefonoTutor || "Dato no registrado"}</li>
                            <li><strong>Telefono Fijo:</strong> ${deportista.telefonoFijoTutor || "Dato no registrado"}</li>
                            <li><strong>Facebook del Familiar:</strong> ${deportista.facebookTutor || "Dato no registrado"}</li>
                            <li><strong>Instagram del Familiar:</strong> ${deportista.instagramTutor || "Dato no registrado"}</li>
                            <li><strong>Email del responsable:</strong> ${deportista.emailResponsable || "Dato no registrado"}</li>
                        </ul>`;
                    break;

                case 'comunicacion':
                    dataHtml = `
                        <ul>
                            <li><strong>Email:</strong> ${deportista.email || "Dato no registrado"}</li>
                            <li><strong>Teléfono:</strong> ${deportista.telefonoJugador || "Dato no registrado"}</li>
                            <li><strong>Telefono de emergencia:</strong> ${deportista.telefonoEmergencia || "Dato no registrado"}</li>
                            <li><strong>Instagram:</strong> ${deportista.instagram || "Dato no registrado"}</li>
                            <li><strong>Facebook:</strong> ${deportista.facebook || "Dato no registrado"}</li>
                        </ul>`;
                    break;
            }

            // Mostrar los datos correspondientes en otro modal
            Swal.fire({
                title: `Datos de ${capitalize(section)}`,
                html: dataHtml,
                confirmButtonText: 'Cerrar',
                confirmButtonColor: "#d33",
            }).then((result) => {
                if (result.isConfirmed) {
                    verDetalle(deportista)
                }
            });
        }

        function capitalize(text) {
            return text.charAt(0).toUpperCase() + text.slice(1);
        }

        function getPagosPorDeportista(id) {
            fetch(`/getPagos/${id}`, {
                method: 'GET',
                headers: {
                    'Content-Type': 'application/json',
                },
            }).then((response) => response.json())
                .then((data) => {
                    const contenido = `
                <h2 style="text-align:center; margin-bottom: 20px;">Pagos de la cuota</h2>
                <div style="max-height: 300px; overflow-y: auto;">
                    <table style="width:100%; border-collapse: collapse;">
                        <thead>
                            <tr>
                                <th style="padding: 10px; border-bottom: 2px solid #ccc; text-align:left; background-color: #f4f4f4;">N° de Referencia</th>
                                <th style="padding: 10px; border-bottom: 2px solid #ccc; text-align:left; background-color: #f4f4f4;">Fecha de pago</th>
                                <th style="padding: 10px; border-bottom: 2px solid #ccc; text-align:left; background-color: #f4f4f4;">Monto</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${data.data && data.data.length > 0 ? data.data.map((pago) => `
                            <tr>
                                <td style="padding: 10px; border-bottom: 1px solid #ddd; text-align: left;">${pago.id}</td>
                                <td style="padding: 10px; border-bottom: 1px solid #ddd; text-align: left;">${pago.fecha}</td>
                                <td style="padding: 10px; border-bottom: 1px solid #ddd; text-align: left;">$${pago.valor}</td>
                            </tr>
                            `).join('')
                            : `
                            <tr>
                                <td colspan="3" style="padding: 10px; text-align: center; color: #999;">Sin pagos registrados</td>
                            </tr>`}
                        </tbody>
                    </table>
                </div>
            `;

                    // Muestra el modal con SweetAlert
                    Swal.fire({
                        html: contenido,
                        showConfirmButton: false,
                        showCloseButton: true,
                        showCancelButton: false,
                    });
                })
        }


        function modalListaDeudores() {

            Swal.fire({
                title: 'Seleccionar Mes y Año',
                html: `
                <input type="month" id="mesDeuda" class="swal2-input" required>
            `,
                showCancelButton: true,
                confirmButtonText: 'OK',
                confirmButtonColor: "#4CAF50",
                cancelButtonText: 'Cancelar',
                preConfirm: () => {
                    const mes = document.getElementById('mesDeuda').value;
                    if (!mes) {
                        Swal.showValidationMessage('Por favor selecciona un mes');
                    }
                    return mes;
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    const mesSeleccionado = result.value;
                    window.location.href = `/dashboard/deportistas/${disciplinaActual}/pagos/listadeudores/${mesSeleccionado}`;
                }
            });

        }
    </script>
</body>

</html>