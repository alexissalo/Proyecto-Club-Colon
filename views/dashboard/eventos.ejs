<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="shortcut icon" href="/public/img/logo_colon_sin_fondo.ico" type="image/x-icon">
    <link rel="stylesheet" href="/public/css/styles.css">
    <style>
        form#eventForm {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            padding: 1rem;

            border-radius: 8px;

        }

        form#eventForm label {
            font-weight: bold;
            font-size: 1rem;
            color: #333;
        }

        form#eventForm input[type="text"],
        form#eventForm input[type="date"],
        form#eventForm textarea {
            width: 100%;
            padding: 0.5rem;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 1rem;
            color: #333;
            background-color: #fff;
        }

        form#eventForm textarea {
            resize: none;
            min-height: 100px;
        }

        form#eventForm button {
            padding: 0.75rem 1.5rem;
            background-color: #4CAF50;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 1rem;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

        form#eventForm button:hover {
            background-color: #45a049;
        }

        form#eventForm button:active {
            background-color: #3e8e41;
        }

        .modal-content {
            border: none;
        }

        .calendario-container{
            background-color: white;
            padding: 10px;
            border-radius: 5px;
        }
    </style>
    <title>Eventos Generales</title>
</head>

<body>
    <div class="grid-container">
        <%- include('header') %>
            <%- include('sidebar',{ rolId: rolId, rolNombre:rolNombre, disciplinas:disciplinas }) %>

                <!-- Main -->
                <main class="main-container">
                    <div class="main-title">
                        <h2>EVENTOS GENERALES</h2>
                    </div>
                    <div class="calendario-container">
                        <div id='calendar'></div>
                    </div>
                </main>
                <!-- End Main -->
    </div>

    <script src="/public/js/interacciones.js"></script>
    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js'></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {

            const eventosData = <%- JSON.stringify(eventos) %>;

            var calendarEl = document.getElementById('calendar');
            let rolNombre = '<%= rolNombre %>';
            var calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                locale: "es",
                headerToolbar: {
                    left: "prev,next,today",
                    center: "title",
                    right: "dayGridMonth,timeGridWeek,listWeek"
                },
                buttonText: {
                    today: 'Hoy',
                    month: 'Mes',
                    week: 'Semana',
                    list: 'Lista'
                },
                selectable: true,

                dateClick: function (info) {
                        if (rolNombre === 'admin_general') {
                            abrirModal(info);
                            document.getElementById('eventForm').addEventListener('submit', añadirEvento);
                        } else {
                            alert("No tienes permisos para añadir eventos.");
                        }
                },
                eventClick: function (info) {
                    mostrarEvento(info.event);
                },
                events: eventosData,
            });
            calendar.render();

            function abrirModal(info) {
                Swal.fire({
                    html: `
                        <h2>Crear Evento</h2>
                        <form id="eventForm">
                            <label for="title">Título:</label>
                            <input type="text" id="title" name="title" required>

                            <label for="start">Fecha de Inicio:</label>
                            <input type="date" id="start" name="start" value=${info.dateStr} required>

                            <label for="end">Fecha de Fin:</label>
                            <input type="date" id="end" value=${info.dateStr} name="end">

                            <label for="description">Descripción:</label>
                            <textarea id="description" name="description"></textarea>

                            <button>Guardar Evento</button>
                        </form>
                    `,
                    showCloseButton: true,
                    focusConfirm: false,
                    showConfirmButton: false,
                    allowOutsideClick: false,
                });
            }


            function mostrarEvento(event) {
                console.log(event);
                let rolNombre = '<%= rolNombre %>';
                const id = parseInt(event.id)
                Swal.fire({
                    html: `
                        <div class="modal-content">
                            <h2>Detalles del Evento</h2>
                            <p><strong>Título:</strong>${event.title}</p>
                            <p><strong>Fecha de Inicio:</strong>${event.start.toLocaleDateString()}</p>
                            <p><strong>Fecha de Fin:</strong>${event.end ? event.end.toLocaleDateString() : "No especificada"}</p>
                            <p><strong>Descripción:</strong>${event.extendedProps.description ? event.extendedProps.description : "No especificada"}</p>
                        </div>
                    `,
                    showCloseButton: true,
                    focusConfirm: false,
                    showConfirmButton: true,
                    confirmButtonColor: "#FF0000",
                    confirmButtonText: "Borrar"

                }).then((result) => {
                    console.log(result.isConfirmed);
                    if (result.isConfirmed && rolNombre === "admin_general") {
                        Swal.fire({
                            title: "Estas seguro?",
                            icon: "warning",
                            showCancelButton: true,
                            confirmButtonColor: "#3085d6",
                            cancelButtonColor: "#d33",
                            cancelButtonText: "Cancelar",
                            confirmButtonText: "Borrar"
                        }).then((result) => {
                            if (result.isConfirmed) {
                                borrarEvento(id)
                                Swal.fire({
                                    title: "Borrado!",
                                    text: "Tu evento ha sido borrado.",
                                    icon: "success"
                                }).then((response) => {
                                    if (result.isConfirmed) {
                                        window.location.reload()
                                    }
                                })
                            }
                        });
                    } else {
                        if (result.isConfirmed) {
                            alert("No tienes permiso para borrar eventos")
                        }
                    }
                })

            }
            function añadirEvento(e) {
                e.preventDefault();
                const nombre = document.getElementById("title").value;
                const fechaInicio = document.getElementById("start").value;
                const fechaFin = document.getElementById("end").value;
                const descripcion = document.getElementById("description").value;

                let eventEnd = fechaFin;

                if (fechaInicio === fechaFin) {
                    eventEnd = null;
                }

                const eventData = {
                    nombre: nombre,
                    fechaInicio: fechaInicio,
                    fechaFin: eventEnd,
                    descripcion: descripcion,
                    disciplina: null
                };

                console.log(eventData);


                fetch('/eventos', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(eventData)
                })
                    .then((response) => {
                        if (response.ok) {
                            window.location.reload();
                        } else {
                            console.error('Response error:', response.status, response.statusText);
                        }
                    })
                    .catch(error => console.error('Error:', error));
            }

            function borrarEvento(id) {
                fetch(`/eventos/${id}`, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                    .then((response) => {
                        if (response.ok) {
                            window.location.reload();
                        } else {
                            console.error('Response error:', response.status, response.statusText);
                        }
                    })
                    .catch(error => console.error('Error:', error));
            }

        })
    </script>
</body>

</html>