<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Productos</title>
    <link rel="stylesheet" href="/public/css/styles.css">
    <link rel="shortcut icon" href="/public/img/logo_colon_sin_fondo.ico" type="image/x-icon">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        .main-container a {
            text-decoration: none;
            padding: 0.75rem 1.5rem;
            background-color: #4CAF50;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 1rem;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

        .formProducto,
        .formProductoEditar {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            padding: 1rem;
        }

        .formProducto label,
        .formProductoEditar label {
            font-weight: bold;
            font-size: 1rem;
            color: #333;
        }

        .formProducto input,
        .formProductoEditar input,
        #tipoSocio,
        #deporte,
        #tipoSocioEditar,
        #deporteEditar {
            width: 100%;
            padding: 0.5rem;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 1rem;
            color: #333;
            background-color: #fff;
        }

        .formProducto button,
        .formProductoEditar button {
            padding: 0.75rem 1.5rem;
            background-color: #4CAF50;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 1rem;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

        .formProducto button:hover,
        .formProductoEditar button:hover {
            background-color: #45a049;
        }

        .formProducto button:active,
        .formProductoEditar button:active {
            background-color: #3e8e41;
        }

        .preview-wrap {
            display: flex;
            justify-content: center;
            align-items: center;
            margin-top: 12px;
        }

        .preview-box {
            width: 280px;
            height: 200px;
            border: 2px dashed #ccc;
            border-radius: 12px;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            background: #fafafa;
        }

        .preview-box img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }

        .file-help {
            font-size: 12px;
            color: #666;
            text-align: center;
            margin-top: 6px;
        }

        .formProducto label {
            display: block;
            margin-top: 8px;
            font-weight: 600;
        }

        .formProducto input,
        .formProducto textarea,
        .formProducto select,
        .formProductoEditar input,
        .formProductoEditar textarea,
        .formProductoEditar select {
            width: 100%;
            padding: 8px;
            border: 1px solid #ddd;
            border-radius: 8px;
            margin-top: 4px;
        }

        .formProducto button,
        .formProductoEditar button {
            margin-top: 12px;
            width: 100%;
            padding: 10px;
            border-radius: 10px;
        }

        /* Fondo oscuro */
        .modal {
        display: none; /* Oculto por defecto */
        position: fixed;
        z-index: 1000;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        overflow: auto;
        background-color: rgba(0,0,0,0.5); /* Fondo semi-transparente */
        }

        /* Contenedor del modal */
        .modal-content {
        background: #fff;
        margin: 5% auto;
        padding: 20px 25px;
        border-radius: 12px;
        width: 90%;
        max-width: 500px;
        box-shadow: 0 6px 15px rgba(0,0,0,0.2);
        animation: fadeIn 0.3s ease-in-out;
        }

        /* Botón de cerrar */
        .close {
        color: #666;
        float: right;
        font-size: 24px;
        font-weight: bold;
        cursor: pointer;
        transition: color 0.2s ease;
        }
        .close:hover {
        color: #e74c3c;
        }

        /* Título */
        .modal-content h3 {
        margin-top: 0;
        margin-bottom: 15px;
        font-size: 20px;
        font-weight: 600;
        color: #333;
        text-align: center;
        }

        /* Inputs y selects */
        .modal-content label {
        display: block;
        font-weight: 500;
        margin: 10px 0 5px;
        color: #444;
        }

        .modal-content input[type="text"],
        .modal-content input[type="number"],
        .modal-content select {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid #ccc;
        border-radius: 6px;
        font-size: 14px;
        margin-bottom: 12px;
        transition: border 0.2s ease;
        }

        .modal-content input[type="text"],
        .modal-content input[type="number"] {
             width: 95%;
        }

        .modal-content input:focus,
        .modal-content select:focus {
        border-color: #007bff;
        outline: none;
        }

        /* Botón */
        .modal-content .btn {
        display: block;
        width: 100%;
        background: #007bff;
        color: #fff;
        font-weight: 600;
        border: none;
        padding: 10px 15px;
        border-radius: 6px;
        cursor: pointer;
        transition: background 0.2s ease;
        }
        .modal-content .btn:hover {
        background: #0056b3;
        }

        /* Animación de entrada */
        @keyframes fadeIn {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
        }


        /* 🔹 Botón principal */
        .btn-primary {
        background: #007bff;
        color: #fff;
        font-weight: 600;
        border: none;
        padding: 10px 18px;
        border-radius: 6px;
        cursor: pointer;
        transition: background 0.2s ease, transform 0.1s ease;
        }
        .btn-primary:hover {
        background: #0056b3;
        transform: translateY(-1px);
        }
        .btn-primary:active {
        transform: translateY(0);
        }

        /* 🔹 Botón secundario (ej. filtros) */
        .btn-secondary {
        background: #6c757d;
        color: #fff;
        font-weight: 500;
        border: none;
        padding: 10px 16px;
        border-radius: 6px;
        cursor: pointer;
        transition: background 0.2s ease;
        }
        .btn-secondary:hover {
        background: #565e64;
        }

        /* 🔹 Botones en la tabla */
        table button {
        background: #f1f1f1;
        border: 1px solid #ccc;
        padding: 6px 12px;
        font-size: 13px;
        border-radius: 6px;
        margin: 2px;
        cursor: pointer;
        transition: background 0.2s ease, color 0.2s ease;
        }
        table button:hover {
        background: #e2e6ea;
        }

        /* 🔹 Acciones específicas */
        table button.editar {
        background: #ffc107;
        color: #000;
        border: none;
        }
        table button.editar:hover {
        background: #e0a800;
        }

        table button.eliminar {
        background: #dc3545;
        color: #fff;
        border: none;
        }
        table button.eliminar:hover {
        background: #c82333;
        }

        table button.ver {
        background: #17a2b8;
        color: #fff;
        border: none;
        }
        table button.ver:hover {
        background: #117a8b;
        }

        table button.stock {
        background: #28a745;
        color: #fff;
        border: none;
        }
        table button.stock:hover {
        background: #218838;
        }

        /* 🔹 Input de búsqueda */
        .search-input {
        padding: 8px 12px;
        border-radius: 6px;
        border: 1px solid #ccc;
        width: 220px;
        font-size: 14px;
        }
        .search-button {
        background: #007bff;
        color: black;
        border: none;
        padding: 8px 14px;
        border-radius: 6px;
        margin-left: 5px;
        cursor: pointer;
        transition: background 0.2s ease;
        }
        .search-button:hover {
        background: #0056b3;
        }

    </style>
</head>

<body>
    <div class="grid-container">
        <%- include('header') %> <%- include('sidebar',{ rolId: rolId, rolNombre:rolNombre, disciplinas:disciplinas })
                %>

                <!-- Main -->
                <main class="main-container">
                    <h1>PRODUCTOS</h1>

                    <!-- Botón para agregar producto -->
                    <button onclick="añadirProducto()" class="btn btn-primary">Agregar Producto</button>

                    <div class="container-tablas">
                        <div class="tabla-header">
                            <div>
                                <form action="" method="GET" class="search-bar">
                                    <input type="text" name="buscar" class="search-input"
                                        placeholder="Buscar por nombre"
                                        value="<%= typeof buscar !== 'undefined' ? buscar : '' %>">
                                    <button type="submit" class="search-button">Buscar</button>
                                </form>
                            </div>

                            <button class="btn btn-secondary" onclick="document.getElementById('filtrosModal').style.display='block'">
                                <i class="bi bi-funnel"></i> Filtros
                            </button>

                            <div id="filtrosModal" class="modal" style="display:none;">
                                <div class="modal-content">
                                    <span class="close" onclick="document.getElementById('filtrosModal').style.display='none'">&times;</span>
                                    <h3>Filtrar productos</h3>
                                    <form method="get" action="/dashboard/productos">
                                    <input type="hidden" name="pagina" value="1">

                                    <label>Categoría:</label>
                                    <select name="categoria" id="">
                                        <option value="">Ninguna</option>
                                        <% categorias.forEach(function(categoria) { %>
                                            <option value = "<%=categoria.nombre%>" <%= stock===categoria.nombre ? 'selected' : ''%>><%=categoria.nombre%></option>
                                        <% })%>
                                    </select>

                                    <label>Stock:</label>
                                    <select name="stock">
                                        <option value="">Todos</option>
                                        <option value="disponible" <%= stock==='disponible' ? 'selected' : '' %>>Disponible</option>
                                        <option value="agotado" <%= stock==='agotado' ? 'selected' : '' %>>Agotado</option>
                                    </select>

                                    <label>Precio mínimo:</label>
                                    <input type="number" step="0.01" name="precioMin" value="<%= precioMin || '' %>">

                                    <label>Precio máximo:</label>
                                    <input type="number" step="0.01" name="precioMax" value="<%= precioMax || '' %>">

                                    <button type="submit" class="btn btn-primary">Aplicar filtros</button>
                                    </form>
                                </div>
                            </div>

                        </div>
                        <table>
                            <thead>
                                <tr>
                                    <th>Nombre</th>
                                    <th>Descripción</th>
                                    <th>Precio</th>
                                    <th>Categoría</th>
                                    <th>Imágenes</th>
                                    <th>Stock</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (productos.length> 0) { %>
                                    <% productos.forEach(function(producto) { %>
                                        <tr>
                                            <td>
                                                <%= producto.nombre %>
                                            </td>
                                            <td>
                                                <%= producto.descripcion %>
                                            </td>
                                            <td>
                                                <%= producto.precio %>
                                            </td>
                                            <td>
                                                <%= producto.categoria %>
                                            </td>
                                            <!-- Columna Imágenes -->
                                            <td>
                                                <button
                                                    class="ver"
                                                    onclick='verImagenes(<%- JSON.stringify(producto.imagenes || []) %>)'>
                                                    Ver Imágenes
                                                </button>
                                            </td>
                                            <!-- Columna stock -->
                                            <td>
                                                <button class="stock" onclick='verStock(<%- JSON.stringify(producto.stock || {}) %>)'>
                                                    Ver Stock
                                                </button>
                                            </td>

                                            <td>
                                                <button class="editar" onclick="editarProducto(<%= JSON.stringify(producto) %>)">Editar</button>
                                                <button class="eliminar" onclick="borrarProducto(<%= producto.id_producto%>)">Eliminar</button>
                                                <button stock="stock" onclick="agregarStock(<%= producto.id_producto %>)">Añadir
                                                    Stock</button>
                                            </td>
                                        </tr>
                                        <% }); %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="8" style="text-align: center;">No hay productos
                                                        registrados</td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                        <div class="pagination">
                            <div class="pagination-select">
                                Filas por pagina:
                                <select
                                    onchange="window.location.href = '?pagina=1' +
                                    '&filasPorPagina=' + this.value +
                                    '&buscar=<%= typeof buscar !== 'undefined' ? buscar : '' %>' +
                                    '&categoria=<%= typeof categoria !== 'undefined' ? categoria : '' %>' +
                                    '&stock=<%= typeof stock !== 'undefined' ? stock : '' %>' +
                                    '&precioMin=<%= typeof precioMin !== 'undefined' ? precioMin : '' %>' +
                                    '&precioMax=<%= typeof precioMax !== 'undefined' ? precioMax : '' %>'">
                                    <option value="5" <%=filasPorPagina==5 ? 'selected' : '' %>>5</option>
                                    <option value="10" <%=filasPorPagina==10 ? 'selected' : '' %>>10</option>
                                    <option value="20" <%=filasPorPagina==20 ? 'selected' : '' %>>20</option>
                                </select>
                            </div>
                            <div class="pagination-buttons">
                                <button class="pagination-button" onclick="navigatePage('prev')" <%=pagina===1
                                    ? 'disabled' : '' %>>
                                    <i class="bi bi-chevron-left"></i>
                                </button>
                                <span>
                                    <%= (pagina - 1) * filasPorPagina + 1 %> - <%= Math.min(pagina * filasPorPagina,
                                            totalProductos) %> de <%= totalProductos %>
                                </span>
                                <button class="pagination-button" onclick="navigatePage('next')" <%=pagina>=
                                    Math.ceil(totalProductos / filasPorPagina) ? 'disabled' : '' %>>
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </main>

                <!-- End Main -->
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/public/js/interacciones.js"></script>

    <script>
        const categoriaData = <%- JSON.stringify(categorias) %>;
        const tallesData = <%- JSON.stringify(talles) %>;

        function navigatePage(direction) {
            const paginaActual = <%= pagina %>;
            const filasPorPaginas = <%= filasPorPagina %>;
            const buscar = '<%= typeof buscar !== "undefined" ? buscar : "" %>';
            const categoria = '<%= typeof categoria !== "undefined" ? categoria : "" %>';
            const stock = '<%= typeof stock !== "undefined" ? stock : "" %>';
            const precioMin = '<%= typeof precioMin !== "undefined" ? precioMin : "" %>';
            const precioMax = '<%= typeof precioMax !== "undefined" ? precioMax : "" %>';

            let nuevaPagina;
            if (direction === 'prev') {
                nuevaPagina = paginaActual - 1;
            } else if (direction === 'next') {
                nuevaPagina = paginaActual + 1;
            }

            window.location.href =
                `?pagina=${nuevaPagina}` +
                `&filasPorPagina=${filasPorPaginas}` +
                `&buscar=${buscar}` +
                `&categoria=${categoria}` +
                `&stock=${stock}` +
                `&precioMin=${precioMin}` +
                `&precioMax=${precioMax}`;
        }

        function añadirProducto() {
            const categoriasHTML = categoriaData.map((categoria) => {
                return `<option value = "${categoria.id_categoria}">${categoria.nombre}</option>`
            }).join('');
            Swal.fire({
                title: 'Agregar nuevo producto',
                html: `
              <style>
                .preview-wrap {
                  display: flex;
                  flex-wrap: wrap;
                  gap: 10px;
                  justify-content: center;
                  margin-top: 12px;
                }
                .preview-box {
                  width: 120px; height: 100px;
                  border: 2px dashed #ccc; border-radius: 10px;
                  display:flex; justify-content:center; align-items:center;
                  overflow:hidden; background:#fafafa;
                }
                .preview-box img {
                  max-width: 100%; max-height: 100%; object-fit: contain;
                }
              </style>

              <form class="formProducto">
                <label for="nombre">Nombre:</label>
                <input type="text" id="nombre" required>

                <label for="descripcion">Descripción:</label>
                <textarea id="descripcion" required></textarea>

                <label for="precio">Precio:</label>
                <input type="number" id="precio" required>

                <label for="categoria">Categoría:</label>
                <select id="categoria">
                  ${categoriasHTML}
                  </select>

                <!-- Input de archivo -->
                <label for="imagen">Imágenes del producto:</label>
                <input type="file" id="imagen" accept="image/*" multiple>

                <!-- Vista previa -->
                <div class="preview-wrap" id="previewContainer">
                  <span id="placeholder">Sin imágenes</span>
                </div>

                <button type="submit">Guardar Producto</button>
              </form>
              <div class="error-message"></div>
            `,
                showConfirmButton: false,
                showCloseButton: true,
                showCancelButton: false,
                allowOutsideClick: false,
                didOpen: () => {
                    const inputFile = document.getElementById('imagen');
                    const previewContainer = document.getElementById('previewContainer');
                    const placeholder = document.getElementById('placeholder');

                    inputFile.addEventListener('change', () => {
                        const files = inputFile.files;
                        previewContainer.innerHTML = ''; // limpio previews anteriores

                        if (!files || files.length === 0) {
                            placeholder.style.display = 'inline';
                            return;
                        }

                        placeholder.style.display = 'none';

                        Array.from(files).forEach(file => {
                            const reader = new FileReader();
                            reader.onload = e => {
                                const box = document.createElement('div');
                                box.classList.add('preview-box');
                                const img = document.createElement('img');
                                img.src = e.target.result;
                                box.appendChild(img);
                                previewContainer.appendChild(box);
                            };
                            reader.readAsDataURL(file);
                        });
                    });
                }
            });

            document.querySelector(".formProducto").addEventListener("submit", async (e) => {
                e.preventDefault();

                const nombre = document.getElementById('nombre').value;
                const descripcion = document.getElementById('descripcion').value;
                const precio = document.getElementById('precio').value;
                const categoria = document.getElementById('categoria').value;
                const imagenes = document.getElementById('imagen').files;

                const formData = new FormData();
                formData.append("nombre", nombre);
                formData.append("descripcion", descripcion);
                formData.append("precio", precio);
                formData.append("id_categoria", categoria);

                // adjunto todas las imágenes seleccionadas
                for (let i = 0; i < imagenes.length; i++) {
                    formData.append("imagenes", imagenes[i]);
                }

                const ajax = await fetch('/crearProducto', {
                    method: 'POST',
                    body: formData
                })
                const result = await ajax.json()
                if (result.ok) {
                    Swal.fire({
                        title: "Producto creado!",
                        text: result.message,
                        icon: "success",
                        showConfirmButton: false,
                        timer: 2000,
                        timerProgressBar: true,
                        didClose: () => {
                            window.location.reload();
                        }
                    });
                } else {
                    document.querySelector(".error-message").textContent = result.message;
                    console.log(result.message)
                }
            });
        }



        function agregarStock(id_producto) {
            Swal.fire({
                title: "Agregar Stock",
                html: `
                <style>
                #formStock {
                        display: grid;
                        grid-template-columns: 1fr 1fr;
                        gap: 12px;
                        text-align: left;
                        font-size: 14px;
                        align-items: center;
                    }
                    #formStock label {
                        font-weight: 600;
                        font-size: 13px;
                    }
                    #formStock input {
                        padding: 6px 8px;
                        border: 1px solid #ddd;
                        border-radius: 6px;
                        font-size: 13px;
                        outline: none;
                        transition: border 0.2s;
                    }
                    #formStock input:focus {
                        border-color: #3085d6;
                        box-shadow: 0 0 3px #3085d6;
                    }
                    #formStock h4 {
                        grid-column: span 2;
                        margin: 5px 0;
                        font-size: 15px;
                        color: #444;
                    }
                    #formStock hr {
                        grid-column: span 2;
                        border: none;
                        border-top: 1px solid #eee;
                        margin: 8px 0;
                    }
                    #formStock button {
                        grid-column: span 2;
                        margin-top: 5px;
                        padding: 10px;
                        background: #3085d6;
                        color: #fff;
                        border: none;
                        border-radius: 6px;
                        cursor: pointer;
                        font-size: 15px;
                        font-weight: bold;
                        transition: background 0.3s;
                    }
                    #formStock button:hover {
                        background: #2563eb;
                    }
                    .error-message {
                        grid-column: span 2;
                        margin-top: 5px;
                        color: red;
                        font-size: 13px;
                        font-weight: 500;
                    }

                    @media (max-width: 600px) {
                        #formStock {
                            grid-template-columns: 1fr !important;
                        }
                        #formStock h4,
                        #formStock hr,
                        #formStock button,
                        .error-message {
                            grid-column: span 1 !important;
                        }
                    }
                </style>
              <form id="formStock">
                <label for="stockGeneral">Stock General:</label>
                <input type="number" id="stockGeneral" placeholder="Cantidad" />

                <hr/>
                <h4>Por Talle:</h4>
                ${tallesData.map(t => `
                    <div>
                        <label for="talle-${t.id_talle}">${t.nombre}:</label>
                        <input type="number" id="talle-${t.id_talle}" data-id="${t.id_talle}" placeholder="Cantidad"/>
                    </div>
                `).join("")}

                <button type="submit">Guardar</button>
              </form>
              <div class="error-message"></div>
            `,
                showConfirmButton: false,
                showCloseButton: true,
                allowOutsideClick: false,
                didOpen: () => {
                    document.getElementById("formStock").addEventListener("submit", async (e) => {
                        e.preventDefault();

                        // Construir array de stocks
                        const stocks = [];

                        // Stock general
                        const generalValue = document.getElementById("stockGeneral").value;
                        if (generalValue) {
                            stocks.push({ id_talle: null, cantidad: parseInt(generalValue, 10) });
                        }

                        // Stock por talle
                        tallesData.forEach(t => {
                            const input = document.getElementById(`talle-${t.id_talle}`);
                            const value = input.value;
                            if (value) {
                                stocks.push({ id_talle: t.id_talle, cantidad: parseInt(value, 10) });
                            }
                        });

                        try {
                            const res = await fetch("/agregarStock", {
                                method: "POST",
                                headers: {
                                    "Content-Type": "application/json"
                                },
                                body: JSON.stringify({ id_producto, stocks })
                            });

                            const data = await res.json();
                            if (data.ok) {
                                Swal.fire({
                                    icon: "success",
                                    title: "Stock actualizado",
                                    text: data.message,
                                    timer: 2000,
                                    showConfirmButton: false
                                }).then(() => window.location.reload());
                            } else {
                                document.querySelector(".error-message").textContent = data.message;
                            }
                        } catch (err) {
                            console.error(err);
                            document.querySelector(".error-message").textContent = "Error al conectar con el servidor.";
                        }
                    });
                }
            });
        }


        function verImagenes(imagenes) {
            if (!imagenes || imagenes.length === 0) {
                return Swal.fire({
                    title: "Sin imágenes",
                    text: "Este producto no tiene imágenes registradas.",
                    icon: "info"
                });
            }

            const galeria = imagenes.map((img )=>
                `<img src="${img}" style="max-width:100%; margin-bottom:10px; border-radius:8px;"/> <hr/>`
            ).join("");

            Swal.fire({
                title: "Imágenes del producto",
                html: `<div style="max-height:400px; overflow-y:auto;">${galeria}</div>`,
                width: 600,
                showCloseButton: true,
                confirmButtonColor: "#4CAF50",
            });
        }

        function verStock(stock) {
            if (!stock || (!stock.general && (!stock.talles || stock.talles.length === 0))) {
                return Swal.fire({
                    title: "Sin stock",
                    text: "Este producto no tiene stock cargado.",
                    icon: "info",
                    confirmButtonColor: "#4CAF50",
                });
            }

            let html = "";
            if (stock.general) {
                html += `<p><b>Stock general:</b> ${stock.general}</p>`;
            }

            if (stock.talles && stock.talles.length > 0) {
                html += "<h4>Stock por talle:</h4><ul style='text-align:left'>";
                stock.talles.forEach(t => {
                    html += `<li>${t.nombre}: ${t.cantidad}</li>`;
                });
                html += "</ul>";
            }

            Swal.fire({
                title: "Stock del producto",
                html: html,
                icon: "info",
                width: 500,
                confirmButtonColor: "#4CAF50",
            });
        }

        function borrarProducto(id) {
            Swal.fire({
                title: "Estas seguro?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                cancelButtonText: "Cancelar",
                confirmButtonText: "Borrar"
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch(`/eliminarProducto/${id}`, {
                        method: 'DELETE',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    }).then((response) => response.json())
                        .then((data) => {
                            if (data.ok) {
                                Swal.fire({
                                    title: "Borrado!",
                                    text: `${data.message}`,
                                    icon: "success",
                                    showConfirmButton: false,
                                    timer: 2000,
                                    timerProgressBar: true,
                                    didClose: () => {
                                        window.location.reload()
                                    } 
                                })
                            } else {
                                Swal.fire({
                                    title: "Error!",
                                    text: `${data.message}`,
                                    icon: "error",
                                    showConfirmButton: false,
                                    timer: 2000,
                                    timerProgressBar: true,
                                    didClose: () => {
                                        window.location.reload()
                                    } 
                                })
                            }
                        })
                        .catch(error => console.error('Error:', error));
                }
            });
        }


        function editarProducto(producto) {
            const categoriasHTML = categoriaData.map((categoria) => {
                const selected= categoria.nombre === producto.categoria ? 'selected' : ''
                return `<option value = "${categoria.id_categoria}" ${selected}>${categoria.nombre}</option>`
            }).join('');
            Swal.fire({
                title: 'Editar producto',
                html: `

              <form class="formProductoEditar">
                <label for="nombre">Nombre:</label>
                <input type="text" id="nombreEditar" value="${producto.nombre}" required>

                <label for="descripcion">Descripción:</label>
                <textarea id="descripcionEditar" required>${producto.descripcion}</textarea>

                <label for="precio">Precio:</label>
                <input type="number" id="precioEditar" value="${producto.precio}" required>

                <label for="categoria">Categoría:</label>
                <select id="categoriaEditar">
                  ${categoriasHTML}
                </select>

                <button type="submit">Guardar Cambios</button>
              </form>
              <div class="error-message"></div>
            `,
                showConfirmButton: false,
                showCloseButton: true,
                showCancelButton: false,
                allowOutsideClick: false,
            });

            document.querySelector(".formProductoEditar").addEventListener("submit", async (e) => {
                e.preventDefault();

                const nombre = document.getElementById('nombreEditar').value;
                const descripcion = document.getElementById('descripcionEditar').value;
                const precio = document.getElementById('precioEditar').value;
                const categoria = document.getElementById('categoriaEditar').value;



                const ajax = await fetch(`/editarProducto/${producto.id_producto}`, {
                    method: 'PUT',
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({ nombre:nombre, descripcion:descripcion, precio:precio, id_categoria:categoria })
                })
                const result = await ajax.json()
                if (result.ok) {
                    Swal.fire({
                        title: "Producto actualizado!",
                        text: result.message,
                        icon: "success",
                        showConfirmButton: false,
                        timer: 2000,
                        timerProgressBar: true,
                        didClose: () => {
                            window.location.reload();
                        }
                    });
                } else {
                    document.querySelector(".error-message").textContent = result.message;
                    console.log(result.message)
                }
            });
        }

    </script>
</body>

</html>